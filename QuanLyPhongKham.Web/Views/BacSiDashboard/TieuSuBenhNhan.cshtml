@model QuanLyPhongKham.Models.DTOs.TieuSuBenhNhan

<div class="p-5 bg-white border border-slate-200 rounded-2xl shadow-md space-y-4">

    <!-- 🔵 HEADER -->
    <div class="flex items-center justify-between border-b pb-3">
        <h2 class="text-lg font-black text-blue-700 uppercase tracking-wide">
            👤 Tiểu sử bệnh nhân
        </h2>
        <span class="text-xs bg-blue-100 text-blue-700 px-3 py-1 rounded-full font-bold">
            Hồ sơ y tế
        </span>
    </div>

    <!-- 🧑 THÔNG TIN CÁ NHÂN -->
    <div class="grid grid-cols-3 gap-3 text-sm">

        <div class="p-3 bg-slate-50 rounded-xl border">
            <p class="text-xs text-slate-500 font-bold uppercase">Họ tên</p>
            <p class="font-semibold text-slate-800">
                @(Model?.ThongTin?.HoTen ?? "Chưa có")
            </p>
        </div>

        <div class="p-3 bg-slate-50 rounded-xl border">
            <p class="text-xs text-slate-500 font-bold uppercase">Giới tính</p>
            <p class="font-semibold text-slate-800">
                @(Model?.ThongTin?.GioiTinh ?? "Chưa có")
            </p>
        </div>

        <div class="p-3 bg-slate-50 rounded-xl border">
            <p class="text-xs text-slate-500 font-bold uppercase">SĐT</p>
            <p class="font-semibold text-slate-800">
                @(Model?.ThongTin?.SoDienThoai ?? "Chưa có")
            </p>
        </div>

    </div>

    <!-- 🟠 TIỀN SỬ -->
    <div class="p-4 border border-orange-200 bg-orange-50 rounded-xl">
        <p class="text-xs font-black text-orange-600 uppercase mb-1">
            🩺 Tiền sử bệnh
        </p>
        <p class="text-sm text-slate-700">
            @(Model?.TienSuBenh ?? "Chưa có thông tin")
        </p>
    </div>

    <!-- 🟢 LỊCH SỬ KHÁM -->
    <div>

        <h3 class="text-sm font-black text-green-700 uppercase mb-2 flex items-center gap-2">
            📋 Lịch sử khám
        </h3>

        <div class="overflow-hidden rounded-xl border border-slate-200">

            <table class="w-full text-sm">

                <thead class="bg-slate-100 text-slate-600 uppercase text-xs">
                    <tr>
                        <th class="p-3 text-left">Ngày khám</th>
                        <th class="p-3 text-left">Kết quả</th>
                        <th class="p-3 text-left">Ghi chú</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model?.LichSuKham != null && Model.LichSuKham.Any())
                    {
                        foreach (var item in Model.LichSuKham)
                        {
                            <tr class="border-t hover:bg-slate-50 transition">
                                <td class="p-3 font-semibold text-slate-700">
                                    @item.NgayKham.ToString("dd/MM/yyyy")
                                </td>
                                <td class="p-3">
                                    <span class="px-2 py-1 rounded-full text-xs font-bold bg-blue-100 text-blue-700">
                                        @(item.KetQua ?? "Chưa có")
                                    </span>
                                </td>
                                <td class="p-3 text-slate-600">
                                    @(item.GhiChu ?? "-")
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="p-4 text-center text-slate-400 italic">
                                Không có lịch sử khám
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>

</div>