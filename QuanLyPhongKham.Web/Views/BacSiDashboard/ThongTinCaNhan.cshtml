@model QuanLyPhongKham.Models.DTOs.XemHoSoBacSiResponse
@{
    ViewData["Title"] = "Thông tin cá nhân";
    Layout = "~/Views/Shared/_BacSiLayout.cshtml";
}
<div class="max-w-3xl mx-auto mt-8 bg-white rounded-xl shadow-md border border-slate-200 overflow-hidden">
    
    <div class="bg-cyan-600 px-6 py-4 flex items-center">
        <i class="fas fa-user-md text-white text-xl mr-3"></i>
        <h2 class="text-xl font-bold text-white mb-0">Hồ sơ Bác sĩ</h2>
    </div>

    <div class="p-8">
        
        @if (TempData["Success"] != null)
        {
            <div class="mb-6 flex items-center bg-green-50 text-green-700 px-4 py-3 rounded-lg border border-green-200 text-sm">
                <i class="fas fa-check-circle mr-2 text-lg"></i>
                <span class="font-medium">@TempData["Success"]</span>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="mb-6 flex items-center bg-red-50 text-red-700 px-4 py-3 rounded-lg border border-red-200 text-sm">
                <i class="fas fa-exclamation-circle mr-2 text-lg"></i>
                <span class="font-medium">@TempData["Error"]</span>
            </div>
        }

        <div class="space-y-6">
            
            <div class="grid grid-cols-1 md:grid-cols-3 border-b border-slate-50 pb-4">
                <div class="text-slate-500 font-semibold uppercase text-xs tracking-wider">Họ tên</div>
                <div class="md:col-span-2 text-slate-800 font-bold text-lg text-blue-700">BS. @Model?.HoTen</div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 border-b border-slate-50 pb-4">
                <div class="text-slate-500 font-semibold uppercase text-xs tracking-wider">Giới tính</div>
                <div class="md:col-span-2 text-slate-800 flex items-center">
                    @if (Model?.GioiTinh == "Nam")
                    {
                        <span class="bg-blue-50 text-blue-700 px-3 py-1 rounded-full text-sm font-medium">👨 Nam</span>
                    }
                    else if (Model?.GioiTinh == "Nữ")
                    {
                        <span class="bg-pink-50 text-pink-700 px-3 py-1 rounded-full text-sm font-medium">👩 Nữ</span>
                    }
                    else
                    {
                        <span class="bg-slate-50 text-slate-600 px-3 py-1 rounded-full text-sm font-medium">⚪ Khác</span>
                    }
                </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 border-b border-slate-50 pb-4">
                <div class="text-slate-500 font-semibold uppercase text-xs tracking-wider">Số điện thoại</div>
                <div class="md:col-span-2 text-slate-800 font-medium">@Model?.SoDienThoai</div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 border-b border-slate-50 pb-4">
                <div class="text-slate-500 font-semibold uppercase text-xs tracking-wider">Địa chỉ</div>
                <div class="md:col-span-2 text-slate-800 leading-relaxed">@Model?.DiaChi</div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 border-b border-slate-50 pb-4 mt-4">
                <div class="text-cyan-600 font-semibold uppercase text-xs tracking-wider flex items-center">
                    <i class="fas fa-stethoscope mr-1.5"></i> Chuyên khoa
                </div>
                <div class="md:col-span-2 text-slate-800 font-bold">@Model?.TenChuyenKhoa</div>
            </div>

            @* <div class="grid grid-cols-1 md:grid-cols-3 pb-2">
                <div class="text-cyan-600 font-semibold uppercase text-xs tracking-wider flex items-center">
                    <i class="fas fa-clinic-medical mr-1.5"></i> Phòng làm việc
                </div>
                <div class="md:col-span-2 text-slate-800 font-bold">@Model?.TenPhong</div>
            </div> *@

        </div>

        <div class="flex justify-end space-x-4 mt-10 pt-6 border-t border-slate-100">
            <a href="@Url.Action("Index", "BacSiDashboard")" class="px-6 py-2.5 bg-slate-100 text-slate-700 rounded-lg hover:bg-slate-200 transition flex items-center font-bold text-sm">
                <i class="fas fa-arrow-left mr-2"></i> Quay lại
            </a>
            <a href="@Url.Action("HoSo", "BacSiDashboard")" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition flex items-center font-bold text-sm shadow-sm hover:shadow-md">
                <i class="fas fa-edit mr-2"></i> Chỉnh sửa
            </a>
        </div>
    </div>
</div>