@{
    Layout = "~/Views/Shared/_BacSiLayout.cshtml";
    ViewData["Title"] = "Trang Chủ Bác Sĩ";
}

<div class="bg-white p-8 rounded-xl shadow-sm border border-slate-200">
    <div class="flex items-center space-x-4 mb-6">
        <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-3xl">
            <i class="fas fa-stethoscope"></i>
        </div>
        <div>
            <h1 class="text-3xl font-black text-slate-800">Xin chào Bác Sĩ! 🩺</h1>
            <p class="text-slate-500">Chúc bác sĩ một ca làm việc hiệu quả và thuận lợi.</p>
        </div>
    </div>
    
    <div class="bg-slate-50 border border-slate-200 p-6 rounded-lg inline-block">
        <p class="text-slate-700 font-medium">
            👉 Bác sĩ vui lòng chuyển sang tab <strong class="font-bold text-blue-600">"Lịch Khám"</strong> bên menu trái để xem danh sách bệnh nhân đang chờ khám ngày hôm nay nhé!
        </p>
    </div>
</div>