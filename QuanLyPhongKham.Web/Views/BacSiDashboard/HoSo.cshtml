@model QuanLyPhongKham.Models.DTOs.XemHoSoBacSiResponse

@{
    ViewData["Title"] = "Hồ sơ của tôi";
    Layout = "~/Views/Shared/_BacSiLayout.cshtml";
}

<div class="max-w-3xl mx-auto mt-6 bg-white rounded-xl shadow-lg overflow-hidden">

    <!-- HEADER -->
    <div class="bg-blue-600 px-6 py-4">
        <h2 class="text-white text-lg font-semibold">
            Hồ sơ cá nhân
        </h2>
    </div>

    <div class="p-6 space-y-6">

        @if (TempData["Success"] != null)
        {
            <div class="bg-green-100 text-green-700 px-4 py-2 rounded">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="bg-red-100 text-red-700 px-4 py-2 rounded">
                @TempData["Error"]
            </div>
        }

        <!-- ================= FORM CẬP NHẬT ================= -->
        <form asp-action="CapNhatHoSo" asp-controller="BacSiDashboard" method="post" class="space-y-4">
            @Html.AntiForgeryToken()

            <div>
                <label class="block font-medium mb-1">Họ tên *</label>
                <input type="text" name="HoTen" value="@Model?.HoTen"
                       class="w-full border rounded-lg px-3 py-2" />
            </div>

            <div>
                <label class="block font-medium mb-1">Giới tính</label>
                <select name="GioiTinh" class="w-full border rounded-lg px-3 py-2">
                    <option value="">--Chọn--</option>
                    <option value="Nam" selected="@(Model?.GioiTinh == "Nam")">Nam</option>
                    <option value="Nữ" selected="@(Model?.GioiTinh == "Nữ")">Nữ</option>
                    <option value="Khác" selected="@(Model?.GioiTinh == "Khác")">Khác</option>
                </select>
            </div>

            <div>
                <label class="block font-medium mb-1">SĐT</label>
                <input type="text" name="SoDienThoai" value="@Model?.SoDienThoai"
                       class="w-full border rounded-lg px-3 py-2" />
            </div>

            <div>
                <label class="block font-medium mb-1">Địa chỉ</label>
                <textarea name="DiaChi" rows="3"
                          class="w-full border rounded-lg px-3 py-2">@Model?.DiaChi</textarea>
            </div>

            <div>
                <label class="block font-medium mb-1">Chuyên khoa</label>
                <select name="ChuyenKhoaId" class="w-full border rounded-lg px-3 py-2">
                    @foreach (var ck in ViewBag.DanhSachChuyenKhoa)
                    {
                        <option value="@ck.Id"
                                selected="@(Model?.ChuyenKhoaId == ck.Id)">
                            @ck.TenKhoa
                        </option>
                    }
                </select>
            </div>

            <button type="submit"
                    class="bg-blue-600 text-white px-5 py-2 rounded-lg">
                Lưu thông tin
            </button>
        </form>

        <!-- ================= FORM ĐỔI MẬT KHẨU ================= -->
        <form asp-action="DoiMatKhau" asp-controller="BacSiDashboard" method="post" class="space-y-4">
            @Html.AntiForgeryToken()

            <h3 class="text-amber-600 font-bold">Đổi mật khẩu</h3>

            <input type="password" name="MatKhauCu" placeholder="Mật khẩu cũ"
                   class="w-full border rounded-lg px-3 py-2" />

            <input type="password" name="MatKhauMoi" placeholder="Mật khẩu mới"
                   class="w-full border rounded-lg px-3 py-2" />

            <input type="password" name="XacNhanMatKhauMoi" placeholder="Xác nhận mật khẩu"
                   class="w-full border rounded-lg px-3 py-2" />

            <button type="submit"
                    class="bg-amber-500 text-white px-5 py-2 rounded-lg">
                Đổi mật khẩu
            </button>
        </form>

    </div>
</div>