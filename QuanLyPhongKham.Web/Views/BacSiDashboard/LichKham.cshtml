@model IEnumerable<QuanLyPhongKham.Models.BuoiKham>
@{
    Layout = "~/Views/Shared/_BacSiLayout.cshtml";
    ViewData["Title"] = "Lịch Của Tôi";
}

<div class="bg-white p-6 rounded-xl shadow border border-slate-200">
    <h2 class="text-xl font-bold mb-4">Danh Sách Bệnh Nhân Của Tôi</h2>
    
    <table class="w-full text-left">
        <tr class="border-b bg-slate-50">
            <th class="py-2 px-2">Thời gian</th>
            <th class="py-2 px-2">Bệnh nhân</th>
            <th class="py-2 px-2">Phòng</th>
            <th class="py-2 px-2">Trạng thái</th>
            <th class="py-2 px-2">Thao tác</th>
        </tr>
        @foreach (var item in Model)
        {
            <tr class="border-b">
                <td class="py-3 px-2">@item.Ngay.ToString("dd/MM/yyyy") - @item.Gio</td>
                <td class="py-3 px-2">@item.BenhNhan?.HoTen</td>
                <td class="py-3 px-2">P.@item.PhongKham?.SoPhong</td>
                <td class="py-3 px-2">
                    @if ((int)item.TrangThai == 0)
                    {
                        <span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded text-xs">Chưa xác nhận</span>
                    }
                    else if ((int)item.TrangThai == 1)
                    {

                        <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs">Đã xác nhận</span>
                    }
                    else if ((int)item.TrangThai == 2)
                    {

                        <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">Hoàn thành</span>
                    }
                    else
                    {

                        <span class="bg-red-100 text-red-700 px-2 py-1 rounded text-xs">Đã hủy</span>
                    }
                </td>
                <td class="py-3 px-2">
                    <form asp-controller="BacSiDashboard" asp-action="DoiTrangThai" method="POST">
                        <input type="hidden" name="id" value="@item.Id" />
        
                        <select name="trangThaiMoi" class="border border-slate-300 p-1.5 rounded text-sm bg-white cursor-pointer hover:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" onchange="this.form.submit()">
            
                            @if ((int)item.TrangThai == 0)
                            {
                                <option value="0" selected>Chưa xác nhận</option>
                            }
                            else
                            {
                                <option value="0">Chưa xác nhận</option>
                            }
                            @if ((int)item.TrangThai == 1)
                            {
                                <option value="1" selected>Đã xác nhận</option>
                            }
                            else
                            {
                                <option value="1">Đã xác nhận</option>
                            }
                            @if ((int)item.TrangThai == 2)
                            {
                                <option value="2" selected>Hoàn thành</option>
                            }
                            else
                            {
                                <option value="2">Hoàn thành</option>
                            }
                            @if ((int)item.TrangThai == 3)
                            {
                                <option value="3" selected>Đã hủy</option>
                            }
                            else
                            {
                                <option value="3">Đã hủy</option>
                            }
            
                        </select>
                    </form>
                </td>
            </tr>
        }
    </table>
</div>