@{
    Layout = "~/Views/Shared/_BenhNhanLayout.cshtml";
    ViewData["Title"] = "Đặt lịch khám";
}

<div class="bg-white p-8 rounded-xl shadow-sm border border-slate-200 max-w-3xl mx-auto mt-6">
    <div class="border-b border-slate-100 pb-4 mb-6">
        <h2 class="text-2xl font-black text-slate-800">Đăng Ký Lịch Khám Bệnh</h2>
        <p class="text-slate-500 text-sm mt-1">Vui lòng điền thông tin để đặt lịch khám với bác sĩ.</p>
    </div>
    
    <!-- Form gửi dữ liệu lên Controller -->
    <form action="/BenhNhanDashboard/DatLich" method="POST">
        <div class="grid grid-cols-2 gap-6 mb-6">
            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Ngày khám <span class="text-red-500">*</span></label>
                <input type="date" name="Ngay" class="w-full border border-slate-300 rounded-lg p-3 text-slate-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" required />
            </div>
            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Khung giờ <span class="text-red-500">*</span></label>
                <input type="time" name="Gio" class="w-full border border-slate-300 rounded-lg p-3 text-slate-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" required />
            </div>
        </div>

        <div class="mb-8">
            <label class="block text-sm font-bold text-slate-700 mb-2">Chọn Bác Sĩ Chuyên Khoa <span class="text-red-500">*</span></label>
            <select name="BacSiId" class="w-full border border-slate-300 rounded-lg p-3 text-slate-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" required>
                <option value="">-- Chọn bác sĩ --</option>
                <!-- Dữ liệu này sau này bạn dùng vòng lặp foreach từ ViewBag/Model để in ra -->
                <option value="1">BS. Trần Văn A - Khoa Tim Mạch</option>
                <option value="2">BS. Lê Thị B - Khoa Thần Kinh</option>
            </select>
        </div>

        <div class="flex justify-end">
            <button type="reset" class="px-6 py-3 text-slate-600 font-bold hover:bg-slate-100 rounded-lg mr-4 transition">Làm lại</button>
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold px-8 py-3 rounded-lg shadow-md shadow-blue-200 transition-all">
                <i class="fas fa-check-circle mr-2"></i> Xác Nhận Đặt Lịch
            </button>
        </div>
    </form>
</div>