@{
    Layout = "~/Views/Shared/_BenhNhanLayout.cshtml";
    ViewData["Title"] = "Đặt Lịch Khám";
}

<div class="bg-white p-8 rounded-xl shadow-sm border border-slate-200 max-w-2xl">
    <h2 class="text-2xl font-bold mb-6">Đăng Ký Khám Bệnh</h2>

    @if (TempData["ThongBao"] != null)
    {
        <div class="bg-green-100 text-green-700 p-3 rounded mb-4">@TempData["ThongBao"]</div>
    }

    <form asp-controller="BenhNhanDashboard" asp-action="DatLich" method="POST">
        <div class="grid grid-cols-2 gap-4 mb-4">
            <div>
                <label class="block font-bold mb-2">Ngày Khám</label>
                <input type="date" name="Ngay" class="w-full border p-2 rounded" required />
            </div>
            <div>
                <label class="block font-bold mb-2">Giờ Khám</label>
                <input type="time" name="Gio" class="w-full border p-2 rounded" required />
            </div>
        </div>

        <div class="mb-4">
            <label class="block font-bold mb-2">Chọn Bác Sĩ</label>
            <select name="BacSiId" class="w-full border p-2 rounded" required>
                <option value="">-- Chọn Bác Sĩ --</option>
                @foreach (var bs in ViewBag.DsBacSi)
                {
                    <option value="@bs.Id">BS. @bs.HoTen</option>
                }
            </select>
        </div>

        <div class="mb-6">
            <label class="block font-bold mb-2">Chọn Phòng Khám</label>
            <select name="PhongKhamId" class="w-full border p-2 rounded" required>
                <option value="">-- Chọn Phòng --</option>
                @foreach (var pk in ViewBag.DsPhongKham)
                {
                    <option value="@pk.Id">Phòng @pk.SoPhong - Tầng @pk.Tang</option>
                }
            </select>
        </div>

        <button type="submit" class="bg-blue-600 text-white font-bold px-6 py-2 rounded hover:bg-blue-700">Xác Nhận Đặt Lịch</button>
    </form>
</div>