@model IEnumerable<QuanLyPhongKham.Models.DTOs.BacSiDanhGiaViewModel>

@{
    Layout = "~/Views/Shared/_BenhNhanLayout.cshtml";
    ViewData["Title"] = "Đội ngũ Bác sĩ";
}

<div class="bg-slate-50 min-h-screen py-10 px-4">
    <div class="max-w-6xl mx-auto">
        
        <div class="mb-8">
            <h2 class="text-3xl font-black text-slate-800 uppercase tracking-tight">Đội ngũ Bác sĩ</h2>
            <p class="text-slate-500 mt-2">Xem thông tin và đánh giá thực tế từ các bệnh nhân đi trước để dễ dàng lựa chọn.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var bs in Model)
            {
                <div class="bg-white rounded-3xl shadow-lg border border-slate-100 overflow-hidden flex flex-col transition-all hover:shadow-xl hover:-translate-y-1">
                    
                    <div class="p-6 border-b border-slate-100 relative overflow-hidden">
                        <div class="absolute top-0 right-0 w-24 h-24 bg-blue-50 rounded-bl-full -z-10"></div>
                        
                        <!-- Tên bác sĩ thành nút bấm (Clickable) -->
                        <h3 class="text-xl font-bold text-slate-800 cursor-pointer hover:text-blue-600 transition-colors inline-flex items-center gap-2"
                            onclick="xemThongTinBacSi(@bs.BacSiId, '@bs.TenChuyenKhoa')"
                            title="Xem chi tiết hồ sơ bác sĩ">
                            BS. @bs.TenBacSi
                            <i class="fas fa-info-circle text-sm text-blue-400 hover:text-blue-600"></i>
                        </h3>
                        
                        <div class="block mt-2">
                            <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-[11px] font-black uppercase tracking-wider inline-block">
                                Khoa @bs.TenChuyenKhoa
                            </span>
                        </div>

                        <div class="mt-5 flex items-center gap-4 bg-slate-50 p-3 rounded-2xl border border-slate-100">
                            <div class="text-4xl font-black text-orange-500">@bs.DiemTrungBinh</div>
                            <div>
                                <div class="text-orange-400 text-sm tracking-widest">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= Math.Round(bs.DiemTrungBinh))
                                        {
                                            <span>⭐</span>
                                        }
                                        else
                                        {
                                            <span class="opacity-30 grayscale">⭐</span>
                                        }
                                    }
                                </div>
                                <div class="text-[11px] text-slate-400 font-bold mt-1 uppercase">Dựa trên @bs.TongSoDanhGia đánh giá</div>
                            </div>
                        </div>
                    </div>

                    <div class="p-6 bg-slate-50 flex-1">
                        <h4 class="text-[11px] font-black text-slate-400 uppercase mb-4 tracking-widest flex items-center gap-2">
                            <span>💬 Lời khen chê gần đây</span>
                        </h4>
                        
                        @if (bs.DanhSachNhanXet.Any())
                        {
                            <div class="space-y-4 max-h-[250px] overflow-y-auto pr-2 custom-scrollbar">
                                @foreach (var nx in bs.DanhSachNhanXet)
                                {
                                    <div class="bg-white p-4 rounded-2xl border border-slate-100 shadow-sm relative">
                                        <div class="flex justify-between items-center mb-2">
                                            <div class="font-bold text-xs text-slate-700">@(nx.TenBenhNhan.Length > 8 ? nx.TenBenhNhan.Substring(0, 8) + "***" : nx.TenBenhNhan)</div>
                                            <div class="text-[10px] text-slate-400 font-medium">@nx.NgayKham.ToString("dd/MM/yyyy")</div>
                                        </div>
                                        <div class="text-orange-400 text-[10px] mb-2 tracking-widest">
                                            @string.Concat(Enumerable.Repeat("⭐", nx.SoSao))
                                        </div>
                                        <p class="text-[13px] text-slate-600 italic leading-relaxed">"@nx.NhanXet"</p>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-10">
                                <div class="text-4xl mb-3 opacity-50">🤫</div>
                                <div class="text-slate-400 text-xs font-medium">Bác sĩ này chưa có đánh giá nào.</div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- ================= MODAL XEM HỒ SƠ BÁC SĨ ================= -->
<div id="bacSiModal" class="hidden fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
    <div class="bg-white rounded-[24px] shadow-2xl w-full max-w-md overflow-hidden transform transition-all scale-95 opacity-0 duration-300" id="bacSiModalContent">
        <div class="bg-blue-600 p-5 text-white flex justify-between items-center">
            <h3 class="font-black text-lg uppercase tracking-tight">Hồ Sơ Bác Sĩ</h3>
            <button onclick="closeBacSiModal()" class="text-white/70 hover:text-white text-2xl font-bold">&times;</button>
        </div>
        <div class="p-6" id="bacSiModalBody">
            <!-- Loading Spinner hiển thị trong lúc chờ gọi API -->
            <div class="flex justify-center py-8">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
            </div>
        </div>
        <div class="p-4 bg-slate-50 border-t flex justify-end gap-3">
            <button onclick="closeBacSiModal()" class="px-6 py-2.5 bg-slate-200 text-slate-700 font-bold rounded-xl hover:bg-slate-300 transition-all uppercase text-xs">Đóng lại</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hàm mở Modal và gọi API lấy dữ liệu Bác sĩ
        function xemThongTinBacSi(id, tenKhoa) {
            // 1. Mở Modal
            $('#bacSiModal').removeClass('hidden').addClass('flex');
            setTimeout(() => {
                $('#bacSiModalContent').removeClass('scale-95 opacity-0').addClass('scale-100 opacity-100');
            }, 10);

            // 2. Set trạng thái loading
            $('#bacSiModalBody').html('<div class="flex justify-center py-8"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div></div>');

            // 3. Gọi AJAX lấy dữ liệu
            $.get('/BenhNhanDashboard/GetThongTinBacSi?id=' + id, function(res) {
                if (res.success) {
                    let d = res.data;
                    let html = `
                        <div class="text-center mb-6">
                            <div class="w-20 h-20 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-3xl font-black mx-auto mb-3 shadow-inner">
                                👨‍⚕️
                            </div>
                            <h4 class="text-xl font-black text-slate-800">${d.hoTen}</h4>
                            <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-[10px] font-black uppercase mt-2 inline-block border border-blue-200">${tenKhoa}</span>
                        </div>
                        <div class="space-y-3">
                            <div class="flex items-center gap-4 p-3 bg-slate-50 rounded-xl border border-slate-100 hover:bg-white hover:shadow-sm transition-all">
                                <div class="w-8 h-8 rounded-full bg-slate-200 text-slate-500 flex items-center justify-center">
                                    <i class="fas fa-venus-mars text-sm"></i>
                                </div>
                                <div>
                                    <p class="text-[10px] font-black text-slate-400 uppercase">Giới tính</p>
                                    <p class="font-bold text-slate-700 text-sm">${d.gioiTinh}</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-4 p-3 bg-slate-50 rounded-xl border border-slate-100 hover:bg-white hover:shadow-sm transition-all">
                                <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-500 flex items-center justify-center">
                                    <i class="fas fa-phone-alt text-sm"></i>
                                </div>
                                <div>
                                    <p class="text-[10px] font-black text-slate-400 uppercase">Số điện thoại</p>
                                    <p class="font-bold text-slate-700 text-sm">${d.sdt}</p>
                                </div>
                            </div>
                            <!-- ĐÃ XÓA KHỐI EMAIL THEO YÊU CẦU -->
                            <div class="flex items-center gap-4 p-3 bg-slate-50 rounded-xl border border-slate-100 hover:bg-white hover:shadow-sm transition-all">
                                <div class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-500 flex items-center justify-center">
                                    <i class="fas fa-map-marker-alt text-sm"></i>
                                </div>
                                <div>
                                    <p class="text-[10px] font-black text-slate-400 uppercase">Địa chỉ công tác</p>
                                    <p class="font-bold text-slate-700 text-sm">${d.diaChi}</p>
                                </div>
                            </div>
                        </div>
                    `;
                    $('#bacSiModalBody').html(html);
                } else {
                    $('#bacSiModalBody').html('<div class="text-center text-red-500 py-6"><i class="fas fa-exclamation-triangle text-3xl mb-2"></i><p class="font-bold">Không thể tải thông tin bác sĩ!</p></div>');
                }
            });
        }

        // Hàm đóng Modal
        function closeBacSiModal() {
            $('#bacSiModalContent').removeClass('scale-100 opacity-100').addClass('scale-95 opacity-0');
            setTimeout(() => {
                $('#bacSiModal').addClass('hidden').removeClass('flex');
            }, 300);
        }
    </script>
}

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 10px;
    }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
</style>