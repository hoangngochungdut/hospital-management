@model IEnumerable<QuanLyPhongKham.Models.BuoiKham>
@{
    Layout = "~/Views/Shared/_BenhNhanLayout.cshtml";
    ViewData["Title"] = "Lịch Khám Của Tôi";
}

<div class="bg-slate-50 min-h-screen py-10 px-4">
    <div class="max-w-5xl mx-auto">
        
        <div class="mb-8 flex justify-between items-end">
            <div>
                <h2 class="text-3xl font-black text-slate-800 uppercase tracking-tight">Lịch Khám Của Tôi</h2>
                <p class="text-slate-500 mt-2">Theo dõi tình trạng và thời gian các ca khám của bạn</p>
            </div>
            <a href="/BenhNhanDashboard/LichKham" class="bg-blue-600 text-white px-6 py-3 rounded-xl font-bold shadow-md hover:bg-blue-700 transition-all">
                + Đặt Lịch Mới
            </a>
        </div>

        <div class="bg-white p-6 rounded-3xl shadow-xl border border-slate-100">
            @if (!Model.Any())
            {
                <div class="text-center py-10">
                    <div class="text-6xl mb-4">🏥</div>
                    <h3 class="text-xl font-bold text-slate-700">Bạn chưa có lịch khám nào</h3>
                    <p class="text-slate-500 mt-2">Hãy đặt lịch ngay để được bác sĩ tư vấn nhé!</p>
                </div>
            }
            else
            {
                <table class="w-full text-left border-collapse">
                    <tr class="border-b-2 border-slate-100 text-slate-500 uppercase text-xs tracking-wider">
                        <th class="py-4 px-4">Ngày Khám</th>
                        <th class="py-4 px-4">Giờ Khám</th>
                        <th class="py-4 px-4">Bác Sĩ Phụ Trách</th>
                        <th class="py-4 px-4">Phòng</th>
                        <th class="py-4 px-4">Trạng Thái</th>
                    </tr>
                    @foreach (var item in Model)
                    {
                        <tr class="border-b border-slate-50 hover:bg-slate-50 transition-colors">
                            <td class="py-4 px-4 font-bold text-slate-700">@item.Ngay.ToString("dd/MM/yyyy")</td>
                            <td class="py-4 px-4 text-blue-600 font-bold">@item.Gio.ToString("HH:mm")</td>
                            <td class="py-4 px-4 font-medium">BS. @item.BacSi?.HoTen</td>
                            <td class="py-4 px-4">
                                <span class="bg-slate-100 text-slate-600 px-3 py-1.5 rounded-lg text-sm font-bold">
                                    P.@item.PhongKham?.SoPhong
                                </span>
                            </td>
                            <td class="py-4 px-4">
                                @if ((int)item.TrangThai == 0)
                                {
                                    <span class="bg-yellow-50 border border-yellow-200 text-yellow-700 px-3 py-1 rounded-full text-xs font-bold">⏳ Chờ xác nhận</span>
                                }
                                else if ((int)item.TrangThai == 1)
                                {
                                    <span class="bg-blue-50 border border-blue-200 text-blue-700 px-3 py-1 rounded-full text-xs font-bold">✅ Đã xác nhận</span>
                                }
                                else if ((int)item.TrangThai == 2)
                                {
                                    <span class="bg-green-50 border border-green-200 text-green-700 px-3 py-1 rounded-full text-xs font-bold">🎉 Hoàn thành</span>
                                }
                                else
                                {
                                    <span class="bg-red-50 border border-red-200 text-red-700 px-3 py-1 rounded-full text-xs font-bold">❌ Đã hủy</span>
                                }
                            </td>
                        </tr>
                    }
                </table>
            }
        </div>
    </div>
</div>