<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Phòng Khám PBL3 - Chăm Sóc Sức Khỏe</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        html { scroll-behavior: smooth; }
        body { font-family: 'Inter', sans-serif; }
        .hero-gradient { background: linear-gradient(135deg, #f0f7ff 0%, #ffffff 100%); }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 antialiased overflow-x-hidden">

    <!-- NAVBAR -->
    <nav class="bg-white/95 backdrop-blur-md shadow-sm sticky top-0 z-50">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center">
            <a href="#" class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-blue-600 text-white rounded-lg flex items-center justify-center text-xl shadow-md">
                    <i class="fas fa-hospital-user"></i>
                </div>
                <div>
                    <h1 class="font-bold text-2xl text-blue-600 leading-none tracking-tight">PBL3</h1>
                </div>
            </a>
            
            <div class="hidden lg:flex items-center space-x-8 font-medium text-slate-600">
                <a href="#" class="text-blue-600 font-semibold border-b-2 border-blue-600 pb-1">Trang chủ</a>
                <a href="#ve-chung-toi" class="hover:text-blue-600 transition">Về chúng tôi</a>
                <a href="#dich-vu" class="hover:text-blue-600 transition">Dịch vụ</a>
                <a href="#doi-ngu" class="hover:text-blue-600 transition">Bác sĩ</a>
                <a href="#lien-he" class="hover:text-blue-600 transition">Liên hệ</a>
            </div>
            
            <!-- KHU VỰC NÚT ĐĂNG NHẬP / ĐĂNG KÝ TRÊN NAVBAR -->
            <div class="hidden md:flex items-center space-x-4">
                <a asp-controller="Account" asp-action="Login" class="text-blue-600 font-semibold hover:text-blue-700 transition">
                   Đăng nhập
                </a>
                <a asp-controller="Account" asp-action="Register" class="bg-blue-600 text-white px-6 py-2.5 rounded-full font-semibold hover:bg-blue-700 transition shadow-lg">
                   Đăng ký
                </a>
            </div>
        </div>
    </nav>

    <!-- THÔNG BÁO THÀNH CÔNG -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="container mx-auto px-6 mt-6">
            <div class="bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-r-lg shadow-sm relative flex items-center justify-between" role="alert">
                <div class="flex items-center">
                    <i class="fas fa-check-circle text-xl mr-3 text-green-500"></i>
                    <div>
                        <strong class="font-bold">Thành công!</strong>
                        <span class="block sm:inline ml-1">@TempData["SuccessMessage"]</span>
                    </div>
                </div>
                <button type="button" class="..." onclick="this.parentElement.parentElement.style.display='none';">
                    <i class="fas fa-times text-lg"></i>
                </button>
            </div>
        </div>
    }

    <!-- HERO SECTION -->
    <section class="hero-gradient py-20">
        <div class="container mx-auto px-6 flex flex-col lg:flex-row items-center gap-12">
            <div class="lg:w-1/2 space-y-6">
                <h1 class="text-4xl lg:text-5xl font-extrabold text-slate-900 leading-tight">
                    Chăm Sóc Sức Khỏe <br> <span class="text-blue-600">Toàn Diện Cho Gia Đình</span>
                </h1>
                <p class="text-lg text-slate-600 leading-relaxed max-w-xl">
                    Với hơn 15 năm kinh nghiệm, PBL3 tự hào mang đến dịch vụ y tế chuẩn mực, công nghệ chẩn đoán hiện đại cùng đội ngũ y bác sĩ tận tâm.
                </p>
                
                <div class="flex gap-4 pt-4 items-center">
                    <a asp-controller="Account" asp-action="Login" class="text-blue-600 font-semibold hover:text-blue-700 transition">
                       Đăng nhập
                </a>
                    <a asp-controller="Account" asp-action="Register" class="bg-blue-600 text-white px-6 py-2.5 rounded-full font-semibold hover:bg-blue-700 transition shadow-lg">
                       Đăng ký
                </a>

                </div>
                </div>

            <div class="lg:w-1/2">
                <img src="https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?auto=format&fit=crop&q=80&w=800" alt="Phòng khám" class="w-full h-[400px] object-cover rounded-2xl shadow-2xl">
            </div>
        </div>
    </section>

    <!-- SECTION VỀ CHÚNG TÔI -->
    <section id="ve-chung-toi" class="py-20 bg-white">
        <div class="container mx-auto px-6 flex flex-col lg:flex-row gap-12 items-center">
            <div class="lg:w-1/2">
                <img src="https://images.hcmcpv.org.vn/res/news/2020/09/25-09-2020-nguoi-bac-si-tan-tam-voi-nghe-chua-benh-cuu-nguoi-958FB4B0-details.jpg?vs=25092020073922" alt="Doctor" class="rounded-2xl shadow-lg w-full h-[350px] object-cover">
            </div>
            <div class="lg:w-1/2">
                <h4 class="text-blue-600 font-bold uppercase text-sm mb-2">Về Chúng Tôi</h4>
                <h2 class="text-3xl font-bold text-slate-900 mb-6">Cam Kết Mang Lại Sức Khỏe Tốt Nhất</h2>
                <p class="text-slate-600 mb-6 leading-relaxed">
                    Phòng Khám PBL3 được thành lập với tâm huyết xây dựng một cơ sở y tế tư nhân đạt chuẩn. Chúng tôi kết hợp giữa chuyên môn y khoa xuất sắc và dịch vụ chăm sóc khách hàng chuyên nghiệp, tận tâm.
                </p>
            </div>
        </div>
    </section>
<!-- SECTION DỊCH VỤ -->
    <section id="dich-vu" class="py-20 bg-slate-50">
        <div class="container mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold text-slate-900 mb-4">Dịch Vụ Y Tế Nổi Bật</h2>
                <div class="w-16 h-1 bg-blue-600 mx-auto rounded-full"></div>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                
                <!-- Dịch vụ 1 -->
                <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 hover:shadow-lg transition">
                    <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center text-2xl mb-6">
                        <i class="fas fa-stethoscope"></i> 
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Khám Tổng Quát</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Gói khám sức khỏe toàn diện giúp phát hiện sớm các nguy cơ bệnh lý, bảo vệ sức khỏe cho bạn và gia đình.</p>
                </div>

                <!-- Dịch vụ 2 -->
                <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 hover:shadow-lg transition">
                    <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center text-2xl mb-6">
                        <i class="fas fa-tooth"></i> 
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Răng Hàm Mặt</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Cung cấp các dịch vụ nha khoa thẩm mỹ, điều trị bệnh lý răng miệng và chăm sóc nụ cười chuyên sâu.</p>
                </div>

                <!-- Dịch vụ 3 -->
                <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 hover:shadow-lg transition">
                    <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center text-2xl mb-6">
                        <i class="fas fa-microscope"></i> 
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Xét Nghiệm Sinh Hóa</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Hệ thống máy móc xét nghiệm hiện đại, trả kết quả nhanh chóng, chính xác hỗ trợ tối đa cho chẩn đoán.</p>
                </div>

                <!-- Dịch vụ 4 -->
                <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 hover:shadow-lg transition">
                    <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center text-2xl mb-6">
                        <i class="fas fa-baby"></i> 
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Nhi Khoa</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Chăm sóc sức khỏe toàn diện cho trẻ sơ sinh và trẻ nhỏ với đội ngũ bác sĩ tận tâm, thấu hiểu tâm lý trẻ.</p>
                </div>

                <!-- Dịch vụ 5 -->
                <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 hover:shadow-lg transition">
                    <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center text-2xl mb-6">
                        <i class="fas fa-x-ray"></i> 
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Chẩn Đoán Hình Ảnh</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Trang bị hệ thống Siêu âm, X-Quang kỹ thuật số thế hệ mới giúp phát hiện chính xác các tổn thương.</p>
                </div>

                <!-- Dịch vụ 6 -->
                <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 hover:shadow-lg transition">
                    <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center text-2xl mb-6">
                        <i class="fas fa-heartbeat"></i> 
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Tim Mạch</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Tầm soát và điều trị các bệnh lý tim mạch, huyết áp với phác đồ chuẩn y khoa theo tiêu chuẩn quốc tế.</p>
                </div>

            </div>
        </div>
    </section>

    <!-- SECTION ĐỘI NGŨ -->
    <section id="doi-ngu" class="py-20 bg-white">
        <div class="container mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold text-slate-900 mb-4">Đội Ngũ Bác Sĩ Đầu Ngành</h2>
                <div class="w-16 h-1 bg-blue-600 mx-auto rounded-full"></div>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                <div class="bg-white rounded-2xl overflow-hidden shadow border border-slate-100">
                    <img src="https://gemini.google.com/97925456-f331-424a-bea6-e28613dd8704" alt="Doctor" class="w-full h-64 object-cover">
                    <div class="p-6 text-center">
                        <h3 class="text-xl font-bold text-slate-900 mb-1">Võ Thành Nhân</h3>
                        <p class="text-blue-600 font-medium text-sm">Khoa Nội</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- form liên hệ -->

<section id="lien-he" class="py-20 bg-slate-50">
    <div class="container mx-auto px-6 max-w-4xl">
        <div class="bg-blue-600 rounded-2xl shadow-xl p-10 text-white text-center">
            <h3 class="text-3xl font-bold mb-8">Thông Tin Liên Hệ</h3>
            <div class="flex flex-col md:flex-row justify-center items-center gap-8 text-left">
                <div class="flex items-center bg-white/10 p-4 rounded-xl">
                    <i class="fas fa-map-marker-alt text-3xl mr-4 text-blue-200"></i>
                    <p>Số 54 Nguyễn Lương Bằng,<br>Hòa Khánh Bắc, Liên Chiểu, Đà Nẵng</p>
                </div>
                <div class="flex items-center bg-white/10 p-4 rounded-xl">
                    <i class="fas fa-phone-alt text-3xl mr-4 text-blue-200"></i>
                    <div>
                        <p class="text-sm text-blue-200">Hotline hỗ trợ</p>
                        <p class="text-2xl font-semibold">0857157006</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

</body>
</html> 