                            <label class="block text-[10px] font-black text-slate-500 uppercase mb-1">Email</label>
                            <input type="email" name="Email" class="w-full border-2 border-slate-200 rounded-xl p-2.5 focus:border-blue-500 outline-none transition-all text-sm" placeholder="email@gmail.com" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-[10px] font-black text-slate-500 uppercase mb-1">Địa chỉ liên hệ</label>
