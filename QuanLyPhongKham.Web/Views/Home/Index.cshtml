                        <input type="text" id="txtSoNha" class="w-full border-2 border-slate-200 rounded-xl p-2.5 focus:border-blue-500 outline-none transition-all text-sm" placeholder="Số nhà, tên đường (Tùy chọn)..." />
                        <input type="hidden" id="DiaChiGop" name="DiaChi" />
                    </div>
                    
                    <button type="submit" class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-black py-3 rounded-xl transition-all shadow-md uppercase mt-3">
                        Tạo Tài Khoản
                    </button>
                </form>

                <form id="formForgotPopup" class="space-y-4 hidden text-left">
                    <div id="forgotError" class="hidden bg-red-50 text-red-600 p-3 rounded-lg text-sm font-bold border border-red-200 text-center"></div>
                    <div id="forgotSuccess" class="hidden bg-green-50 text-green-600 p-3 rounded-lg text-sm font-bold border border-green-200 text-center"></div>
                    
                    <div class="text-center mb-4">
                        <div class="w-12 h-12 bg-orange-100 text-orange-500 rounded-full flex items-center justify-center text-xl mx-auto mb-2"><i class="fas fa-key"></i></div>
                        <h3 class="font-black text-lg text-slate-800 uppercase">Khôi phục mật khẩu</h3>
                        <p class="text-xs text-slate-500 mt-1">Nhập tên đăng nhập, hệ thống sẽ reset mật khẩu cho bạn.</p>
                    </div>
                    <div>
                        <label class="block text-xs font-black text-slate-500 uppercase mb-2">Tên đăng nhập</label>
                        <input type="text" name="Username" class="w-full border-2 border-slate-200 rounded-xl p-3 focus:border-orange-500 outline-none transition-all" required placeholder="Nhập tài khoản của bạn..." />
                    </div>
                    <button type="submit" class="w-full bg-orange-500 hover:bg-orange-600 text-white font-black py-3 rounded-xl transition-all shadow-md uppercase mt-2">
                        Lấy lại mật khẩu
                    </button>
                    <div class="text-center mt-4 border-t border-slate-100 pt-4">
                        <button type="button" onclick="switchAuthTab('login')" class="text-sm text-slate-500 font-bold hover:text-blue-600 transition-colors">
                            <i class="fas fa-arrow-left mr-1"></i> Quay lại Đăng nhập
                        </button>
                    </div>
                </form>

                <form id="formChangePassPopup" class="space-y-4 hidden text-left">
                    <div id="changePassError" class="hidden bg-red-50 text-red-600 p-3 rounded-lg text-sm font-bold border border-red-200 text-center"></div>
                    <div class="text-center mb-4">
                        <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-xl mx-auto mb-2"><i class="fas fa-shield-alt"></i></div>
                        <h3 class="font-black text-lg text-slate-800 uppercase">Đổi mật khẩu mới</h3>
                        <p class="text-xs text-slate-500 mt-1">Vui lòng đổi mật khẩu để tiếp tục sử dụng hệ thống.</p>
                    </div>
                    <input type="hidden" name="TempTaiKhoanId" id="tempTkId" />
                    <div>
                        <label class="block text-xs font-black text-slate-500 uppercase mb-2">Mật khẩu mới</label>
                        <input type="password" name="MatKhauMoi" id="newPass" class="w-full border-2 border-slate-200 rounded-xl p-3 focus:border-blue-500 outline-none" required />
                    </div>
                    <div>
                        <label class="block text-xs font-black text-slate-500 uppercase mb-2">Xác nhận mật khẩu</label>
                        <input type="password" name="XacNhanMatKhauMoi" id="confirmPass" class="w-full border-2 border-slate-200 rounded-xl p-3 focus:border-blue-500 outline-none" required />
                    </div>
                    <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-black py-3 rounded-xl shadow-md uppercase">Xác nhận đổi mật khẩu</button>
                </form>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        function openAuthModal(tab = 'login') {
            $('#authModal').removeClass('hidden').addClass('flex');
            setTimeout(() => {
                $('#authModalContent').removeClass('scale-95 opacity-0').addClass('scale-100 opacity-100');
            }, 10);
            switchAuthTab(tab);
        }

        function closeAuthModal() {
            $('#authModalContent').removeClass('scale-100 opacity-100').addClass('scale-95 opacity-0');
            setTimeout(() => {
                $('#authModal').addClass('hidden').removeClass('flex');
            }, 300);
        }

        function switchAuthTab(tab) {
            $('#authTabsHeader').removeClass('hidden'); 
            $('#loginError, #registerError, #forgotError, #forgotSuccess, #changePassError').addClass('hidden'); 
            $('#formLoginPopup, #formRegisterPopup, #formForgotPopup, #formChangePassPopup').addClass('hidden');
            
            if (tab === 'login') {
                $('#formLoginPopup').removeClass('hidden');
                $('#tabLogin').removeClass('text-slate-400 border-transparent font-bold').addClass('text-blue-600 border-blue-600 font-black');
                $('#tabRegister').removeClass('text-blue-600 border-blue-600 font-black').addClass('text-slate-400 border-transparent font-bold');
            } else if (tab === 'register') {
                $('#formRegisterPopup').removeClass('hidden');
                $('#tabRegister').removeClass('text-slate-400 border-transparent font-bold').addClass('text-blue-600 border-blue-600 font-black');
                $('#tabLogin').removeClass('text-blue-600 border-blue-600 font-black').addClass('text-slate-400 border-transparent font-bold');
            } else if (tab === 'forgot') {
                $('#formForgotPopup').removeClass('hidden');
                $('#authTabsHeader').addClass('hidden');
            } else if (tab === 'changePass') {
                $('#formChangePassPopup').removeClass('hidden');
                $('#authTabsHeader').addClass('hidden');
            }
        }

        $(document).ready(function () {
            
            // XỬ LÝ CHỌN ĐỊA CHỈ TỪ API HÀNH CHÍNH
            let dataHanhChinh = [];
            $.get("https://provinces.open-api.vn/api/?depth=3", function(data) {
                dataHanhChinh = data;
                let htmlTinh = '<option value="">Chọn Tỉnh/Thành</option>';
                dataHanhChinh.forEach(t => { htmlTinh += `<option value="${t.code}">${t.name}</option>`; });
                $('#selTinh').html(htmlTinh);
            });

            $('#selTinh').change(function() {
                let codeTinh = $(this).val();
                $('#selHuyen').html('<option value="">Quận/Huyện</option>').prop('disabled', true);
                $('#selXa').html('<option value="">Phường/Xã</option>').prop('disabled', true);
                
                if (codeTinh) {
                    let tinhSelected = dataHanhChinh.find(t => t.code == codeTinh);
                    let htmlHuyen = '<option value="">Chọn Quận/Huyện</option>';
                    tinhSelected.districts.forEach(h => { htmlHuyen += `<option value="${h.code}">${h.name}</option>`; });
                    $('#selHuyen').html(htmlHuyen).prop('disabled', false);
                }
                gopDiaChi(); 
            });

            $('#selHuyen').change(function() {
                let codeHuyen = $(this).val();
                let codeTinh = $('#selTinh').val();
                $('#selXa').html('<option value="">Phường/Xã</option>').prop('disabled', true);
                
                if (codeHuyen && codeTinh) {
                    let tinhSelected = dataHanhChinh.find(t => t.code == codeTinh);
                    let huyenSelected = tinhSelected.districts.find(h => h.code == codeHuyen);
                    
                    let htmlXa = '<option value="">Chọn Phường/Xã</option>';
                    huyenSelected.wards.forEach(x => { htmlXa += `<option value="${x.code}">${x.name}</option>`; });
                    $('#selXa').html(htmlXa).prop('disabled', false);
                }
                gopDiaChi();
            });

            $('#selXa, #txtSoNha').on('change input', function() { gopDiaChi(); });

            function gopDiaChi() {
                let tenTinh = $('#selTinh').val() ? $('#selTinh option:selected').text() : "";
                let tenHuyen = $('#selHuyen').val() ? $('#selHuyen option:selected').text() : "";
                let tenXa = $('#selXa').val() ? $('#selXa option:selected').text() : "";
                let soNha = $('#txtSoNha').val().trim();

                let diaChiDayDu = [];
                if (soNha) diaChiDayDu.push(soNha);
                if (tenXa) diaChiDayDu.push(tenXa);
                if (tenHuyen) diaChiDayDu.push(tenHuyen);
                if (tenTinh) diaChiDayDu.push(tenTinh);

                $('#DiaChiGop').val(diaChiDayDu.join(', '));
            }

            // XỬ LÝ SUBMIT AJAX ĐĂNG NHẬP
            $('#formLoginPopup').submit(function (e) {
                e.preventDefault();
                let btn = $(this).find('button[type="submit"]');
                let originalText = btn.text();
                btn.html('<i class="fas fa-spinner fa-spin"></i> Đang xử lý...').prop('disabled', true);

                $.post('/Account/LoginAjax', $(this).serialize(), function (res) {
                    if (res.success) {
                        if (res.mustChange) {
                            $('#tempTkId').val(res.tkId);
                            switchAuthTab('changePass');
                        } else {
                            window.location.href = res.redirectUrl; 
                        }
                    } else {
                        $('#loginError').text("❌ " + res.message).removeClass('hidden');
                        btn.html(originalText).prop('disabled', false);
                    }
                });
            });

            // XỬ LÝ SUBMIT AJAX ĐỔI MẬT KHẨU
            $('#formChangePassPopup').submit(function (e) {
                e.preventDefault();
                if($('#newPass').val() !== $('#confirmPass').val()){
                    alert("Xác nhận mật khẩu không khớp!"); return;
                }
                
                let btn = $(this).find('button[type="submit"]');
                let originalText = btn.text();
                btn.html('<i class="fas fa-spinner fa-spin"></i> Đang xử lý...').prop('disabled', true);

                $.post('/Account/DoiMatKhauAjax', $(this).serialize(), function (res) {
                    if (res.success) {
                        alert("✅ Đổi mật khẩu thành công!");
                        window.location.href = res.redirectUrl;
                    } else {
                        $('#changePassError').text("❌ " + res.message).removeClass('hidden');
                        btn.html(originalText).prop('disabled', false);
                    }
                });
            });

            // XỬ LÝ SUBMIT AJAX ĐĂNG KÝ
            $('#formRegisterPopup').submit(function (e) {
                e.preventDefault();
                let btn = $(this).find('button[type="submit"]');
                let originalText = btn.text();
                btn.html('<i class="fas fa-spinner fa-spin"></i> Đang xử lý...').prop('disabled', true);

                $.post('/Account/RegisterAjax', $(this).serialize(), function (res) {
                    if (res.success) {
                        alert("✅ Đăng ký thành công! Hệ thống đang tự động chuyển hướng...");
                        window.location.href = res.redirectUrl;
                    } else {
                        $('#registerError').text("❌ " + res.message).removeClass('hidden');
                        btn.html(originalText).prop('disabled', false);
                    }
                });
            });

            // XỬ LÝ SUBMIT AJAX QUÊN MẬT KHẨU
            $('#formForgotPopup').submit(function (e) {
                e.preventDefault();
                let btn = $(this).find('button[type="submit"]');
                let originalText = btn.text();
                btn.html('<i class="fas fa-spinner fa-spin"></i> Đang xử lý...').prop('disabled', true);

                $.post('/Account/QuenMatKhauAjax', $(this).serialize(), function (res) {
                    if (res.success) {
                        $('#forgotError').addClass('hidden');
                        $('#forgotSuccess').text("✅ " + res.message).removeClass('hidden');
                        btn.html('Hoàn tất').prop('disabled', false);
                        
                        setTimeout(() => switchAuthTab('login'), 3000);
                    } else {
                        $('#forgotSuccess').addClass('hidden');
                        $('#forgotError').text("❌ " + res.message).removeClass('hidden');
                        btn.html(originalText).prop('disabled', false);
                    }
                });
            });
        });
    </script>
</body>
</html>