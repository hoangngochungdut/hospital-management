                    </div>
                    <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-black py-3 rounded-xl transition-all shadow-md uppercase mt-2">
                        Đăng Nhập Ngay
                    </button>
                </form>

                <form id="formRegisterPopup" class="space-y-3 hidden">
                    <div id="registerError" class="hidden bg-red-50 text-red-600 p-3 rounded-lg text-sm font-bold border border-red-200 text-center"></div>
                    
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-[10px] font-black text-slate-500 uppercase mb-1">Tên đăng nhập (*)</label>
                            <input type="text" name="Username" class="w-full border-2 border-slate-200 rounded-xl p-2.5 focus:border-blue-500 outline-none transition-all text-sm" required placeholder="tendangnhap" />
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-slate-500 uppercase mb-1">Mật khẩu (*)</label>
                            <input type="password" name="Password" class="w-full border-2 border-slate-200 rounded-xl p-2.5 focus:border-blue-500 outline-none transition-all text-sm" required placeholder="••••••••" />
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-[10px] font-black text-slate-500 uppercase mb-1">Họ và Tên (*)</label>
                        <input type="text" name="FullName" class="w-full border-2 border-slate-200 rounded-xl p-2.5 focus:border-blue-500 outline-none transition-all text-sm" required placeholder="Nguyễn Văn A" />
                    </div>
                    
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-[10px] font-black text-slate-500 uppercase mb-1">Số điện thoại (*)</label>
                            <input type="text" name="PhoneNumber" class="w-full border-2 border-slate-200 rounded-xl p-2.5 focus:border-blue-500 outline-none transition-all text-sm" required placeholder="0987..." />
