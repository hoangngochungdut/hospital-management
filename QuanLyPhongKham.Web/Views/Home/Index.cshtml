                            </select>
                            <select id="selHuyen" class="w-full border-2 border-slate-200 rounded-xl p-2 focus:border-blue-500 outline-none transition-all text-xs" disabled required>
                                <option value="">Quận/Huyện</option>
                            </select>
                            <select id="selXa" class="w-full border-2 border-slate-200 rounded-xl p-2 focus:border-blue-500 outline-none transition-all text-xs" disabled required>
                                <option value="">Phường/Xã</option>
                            </select>
