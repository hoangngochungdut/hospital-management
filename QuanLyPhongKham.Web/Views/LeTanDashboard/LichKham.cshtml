@{
    Layout = "~/Views/Shared/_LeTanLayout.cshtml";
    ViewData["Title"] = "Lễ Tân Đặt Lịch";
}

<div class="bg-white p-8 rounded-xl shadow-sm border border-slate-200 max-w-2xl">
    <h2 class="text-2xl font-bold mb-6">Lễ Tân: Đặt Lịch Cho Bệnh Nhân</h2>

    @if (TempData["ThongBao"] != null)
    {
        <div class="bg-green-100 text-green-700 p-3 rounded mb-4">@TempData["ThongBao"]</div>
    }

    <form asp-controller="LeTanDashboard" asp-action="DatLich" method="POST">
        <div class="mb-4">
            <label class="block font-bold mb-2">Chọn Bệnh Nhân</label>
            <select name="BenhNhanId" class="w-full border p-2 rounded" required>
                <option value="">-- Chọn Bệnh Nhân --</option>
                @foreach (var bn in ViewBag.DsBenhNhan)
                {
                    <option value="@bn.Id">BN: @bn.HoTen</option>
                }
            </select>
        </div>

        <div class="grid grid-cols-2 gap-4 mb-4">
            <div><label class="block font-bold mb-2">Ngày</label><input type="date" name="Ngay" class="w-full border p-2 rounded" required /></div>
            <div><label class="block font-bold mb-2">Giờ</label><input type="time" name="Gio" class="w-full border p-2 rounded" required /></div>
        </div>

        <div class="mb-4">
            <label class="block font-bold mb-2">Bác Sĩ</label>
            <select name="BacSiId" class="w-full border p-2 rounded" required>
                <option value="">-- Chọn --</option>
                @foreach (var bs in ViewBag.DsBacSi)
                {
                    <option value="@bs.Id">BS. @bs.HoTen</option>
                }
            </select>
        </div>

        <div class="mb-6">
            <label class="block font-bold mb-2">Phòng Khám</label>
            <select name="PhongKhamId" class="w-full border p-2 rounded" required>
                <option value="">-- Chọn --</option>
                @foreach (var pk in ViewBag.DsPhongKham)
                {
                    <option value="@pk.Id">P.@pk.SoPhong (Tầng @pk.Tang)</option>
                }
            </select>
        </div>

        <button type="submit" class="bg-indigo-600 text-white font-bold px-6 py-2 rounded">Xác Nhận</button>
    </form>
</div>