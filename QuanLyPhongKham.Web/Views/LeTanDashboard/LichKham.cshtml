@{
    Layout = "~/Views/Shared/_LeTanLayout.cshtml";
    ViewData["Title"] = "Lễ tân đặt lịch";
}

<div class="bg-white p-8 rounded-xl shadow-sm border border-slate-200 max-w-3xl mx-auto mt-6">
    <div class="border-b border-slate-100 pb-4 mb-6">
        <h2 class="text-2xl font-black text-slate-800">Đặt Lịch Khám Hộ Bệnh Nhân</h2>
        <p class="text-slate-500 text-sm mt-1">Phân hệ dành riêng cho Lễ Tân phòng khám.</p>
    </div>
    
    <form action="/LeTanDashboard/DatLich" method="POST">
        <div class="mb-6">
            <label class="block text-sm font-bold text-slate-700 mb-2">Tìm/Chọn Bệnh Nhân <span class="text-red-500">*</span></label>
            <select name="BenhNhanId" class="w-full border border-slate-300 rounded-lg p-3 text-slate-700 focus:ring-2 focus:ring-blue-500 outline-none" required>
                <option value="">-- Nhập tên hoặc mã bệnh nhân --</option>
                <option value="101">BN101 - Nguyễn Văn Khách</option>
                <option value="102">BN102 - Phạm Thị Bệnh</option>
            </select>
        </div>

        <div class="grid grid-cols-2 gap-6 mb-6">
            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Ngày khám</label>
                <input type="date" name="Ngay" class="w-full border border-slate-300 rounded-lg p-3 text-slate-700 focus:ring-2 focus:ring-blue-500 outline-none" required />
            </div>
            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Khung giờ</label>
                <input type="time" name="Gio" class="w-full border border-slate-300 rounded-lg p-3 text-slate-700 focus:ring-2 focus:ring-blue-500 outline-none" required />
            </div>
        </div>

        <div class="mb-8">
            <label class="block text-sm font-bold text-slate-700 mb-2">Chỉ định Bác Sĩ</label>
            <select name="BacSiId" class="w-full border border-slate-300 rounded-lg p-3 text-slate-700 focus:ring-2 focus:ring-blue-500 outline-none" required>
                <option value="">-- Chọn bác sĩ trực --</option>
                <option value="1">BS. Trần Văn A</option>
            </select>
        </div>

        <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold px-8 py-3 rounded-lg shadow-md transition-all">
            <i class="fas fa-calendar-plus mr-2"></i> Tạo Lịch Khám & Xác Nhận Ngay
        </button>
    </form>
</div>