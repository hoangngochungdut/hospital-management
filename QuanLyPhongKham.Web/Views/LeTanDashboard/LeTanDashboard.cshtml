@{
    Layout = "~/Views/Shared/_LeTanLayout.cshtml";
    ViewData["Title"] = "Trang Chủ Lễ Tân";
}

<div class="bg-white p-8 rounded-xl shadow-sm border border-slate-200">
    <div class="flex items-center space-x-4 mb-6">
        <div class="w-16 h-16 bg-pink-100 text-pink-600 rounded-full flex items-center justify-center text-3xl">
            <i class="fas fa-headset"></i>
        </div>
        <div>
            <h1 class="text-3xl font-black text-slate-800">Xin chào Lễ Tân! 👩‍💼</h1>
            <p class="text-slate-500">Chào mừng bạn đến với ca trực phòng khám PBL3 MED.</p>
        </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
        <div class="bg-indigo-50 border border-indigo-100 p-6 rounded-xl">
            <h3 class="text-indigo-800 font-bold text-lg mb-2"><i class="fas fa-calendar-plus mr-2"></i> Đặt lịch nhanh</h3>
            <p class="text-indigo-600 text-sm mb-4">Hỗ trợ bệnh nhân đăng ký lịch khám mới với bác sĩ chuyên khoa.</p>
            <a href="@Url.Action("LichKham", "LeTanDashboard")" class="bg-indigo-600 text-white px-4 py-2 rounded shadow text-sm font-bold hover:bg-indigo-700 transition">
                Đến trang Đặt lịch
            </a>
        </div>
        
        <div class="bg-teal-50 border border-teal-100 p-6 rounded-xl">
            <h3 class="text-teal-800 font-bold text-lg mb-2"><i class="fas fa-money-check-alt mr-2"></i> Thanh toán</h3>
            <p class="text-teal-600 text-sm mb-4">Xử lý hóa đơn và viện phí cho các ca khám đã hoàn thành.</p>
            <button class="bg-teal-600 text-white px-4 py-2 rounded shadow text-sm font-bold hover:bg-teal-700 transition">
                Chuyển đến Thanh toán
            </button>
        </div>
    </div>
</div>