<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bàn Tiếp Đón (Lễ Tân) - PBL3 Clinic</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .sidebar-item { transition: all 0.2s ease; }
        .sidebar-item:hover { background-color: #f1f5f9; color: #2563eb; }
        .sidebar-active { background-color: #eff6ff; color: #2563eb; border-right: 4px solid #2563eb; font-weight: 600; }
        .glass-header { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(10px); }
    </style>
</head>
<body class="bg-[#f8fafc] text-slate-800 antialiased">

    <div class="flex min-h-screen">
        
        <!-- SIDEBAR (Fixed Left) -->
        <aside class="w-64 bg-white border-r border-slate-200 hidden lg:flex flex-col sticky top-0 h-screen shadow-sm">
            <div class="p-8 border-b border-slate-50 mb-4">
                <div class="flex items-center space-x-3">
                    <div class="w-9 h-9 bg-blue-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-blue-200">
                        <i class="fas fa-heartbeat text-lg"></i>
                    </div>
                    <span class="text-xl font-black tracking-tighter text-slate-800">PBL3<span class="text-blue-600">MED</span></span>
                </div>
            </div>

            <nav class="flex-1 px-4 space-y-1">
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest px-4 mb-2">Không Gian Làm Việc</p>
                <a href="#" class="sidebar-active flex items-center space-x-3 px-4 py-3 rounded-lg sidebar-item">
                    <i class="fas fa-calendar-check w-5"></i>
                    <span>Lịch Khám</span>
                </a>
                <a href="#" class="flex items-center space-x-3 px-4 py-3 rounded-lg sidebar-item text-slate-500">
                    <i class="fas fa-file-invoice-dollar w-5"></i>
                    <span class="flex-1">Thanh Toán</span>
                    <span class="bg-red-500 text-white text-[10px] font-bold px-2 py-0.5 rounded-full">3</span>
                </a>
                
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest px-4 mt-6 mb-2">Dữ Liệu Khách Hàng</p>
                <a href="#" class="flex items-center space-x-3 px-4 py-3 rounded-lg sidebar-item text-slate-500">
                    <i class="fas fa-users w-5"></i>
                    <span>Hồ Sơ Bệnh Nhân</span>
                </a>

                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest px-4 mt-6 mb-2">Tài Khoản</p>
                <a href="#" class="flex items-center space-x-3 px-4 py-3 rounded-lg sidebar-item text-slate-500">
                    <i class="fas fa-user-circle w-5"></i>
                    <span>Thông Tin Cá Nhân</span>
                </a>
            </nav>

            <div class="p-4 border-t border-slate-100">
                <div class="px-4 py-3 mb-2 flex items-center space-x-3">
                    <img src="https://i.pravatar.cc/150?img=47" alt="Lễ Tân" class="w-10 h-10 rounded-full border border-slate-200">
                    <div>
                        <p class="text-sm font-bold text-slate-800">Mai Phương</p>
                        <p class="text-[10px] text-blue-600 font-bold uppercase">Lễ Tân Trực</p>
                    </div>
                </div>
                <a href="#" class="flex items-center space-x-3 px-4 py-3 rounded-lg text-red-500 hover:bg-red-50 transition">
                    <i class="fas fa-sign-out-alt w-5"></i>
                    <span class="font-semibold">Đăng Xuất</span>
                </a>
            </div>
        </aside>

        <!-- MAIN CONTENT AREA -->
        <main class="flex-1 flex flex-col">
            
            <!-- HEADER -->
            <header class="glass-header sticky top-0 z-30 border-b border-slate-200 px-8 py-4 flex justify-between items-center">
                <div>
                    <h1 class="text-lg font-bold text-slate-800">Bàn Tiếp Đón</h1>
                    <p class="text-xs text-slate-500">Thứ Ba, 07 tháng 04, 2026 • Ca Sáng (07:00 - 11:30)</p>
                </div>
                <div class="flex items-center space-x-4">
                    <button class="bg-blue-600 text-white px-5 py-2 rounded-xl font-bold hover:bg-blue-700 transition flex items-center shadow-lg shadow-blue-200 text-sm">
                        <i class="fas fa-user-plus mr-2"></i> Khách Vãng Lai
                    </button>
                    <button class="w-10 h-10 flex items-center justify-center rounded-full bg-slate-100 text-slate-500 hover:bg-blue-50 hover:text-blue-600 transition relative">
                        <i class="fas fa-bell text-sm"></i>
                        <span class="absolute top-0 right-0 w-2.5 h-2.5 bg-red-500 border-2 border-white rounded-full"></span>
                    </button>
                </div>
            </header>

            <!-- LỊCH KHÁM / TIẾP ĐÓN BODY -->
            <div class="p-8 max-w-[1400px] mx-auto w-full">
                
                <!-- TOP STATS (Luồng Khách) -->
                <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
                    <div class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm flex items-center justify-between">
                        <div>
                            <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest">Sắp đến</p>
                            <h3 class="text-3xl font-black text-slate-800 mt-1">12</h3>
                        </div>
                        <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center text-xl"><i class="fas fa-walking"></i></div>
                    </div>
                    <div class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm flex items-center justify-between">
                        <div>
                            <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest">Đang chờ khám</p>
                            <h3 class="text-3xl font-black text-orange-500 mt-1">05</h3>
                        </div>
                        <div class="w-12 h-12 bg-orange-50 text-orange-500 rounded-full flex items-center justify-center text-xl"><i class="fas fa-couch"></i></div>
                    </div>
                    <div class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm flex items-center justify-between">
                        <div>
                            <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest">Đang khám</p>
                            <h3 class="text-3xl font-black text-slate-800 mt-1">03</h3>
                        </div>
                        <div class="w-12 h-12 bg-slate-50 text-slate-600 rounded-full flex items-center justify-center text-xl"><i class="fas fa-stethoscope"></i></div>
                    </div>
                    <div class="bg-white p-5 rounded-2xl border border-green-500 bg-green-50 shadow-sm flex items-center justify-between cursor-pointer hover:bg-green-100 transition">
                        <div>
                            <p class="text-[11px] font-bold text-green-600 uppercase tracking-widest">Chờ thanh toán</p>
                            <h3 class="text-3xl font-black text-green-700 mt-1">03</h3>
                        </div>
                        <div class="w-12 h-12 bg-green-500 text-white rounded-full flex items-center justify-center text-xl shadow-md"><i class="fas fa-money-bill-wave"></i></div>
                    </div>
                </div>

                <!-- Thanh tìm kiếm bệnh nhân -->
                <div class="relative w-full max-w-2xl mb-8">
                    <i class="fas fa-search absolute left-5 top-1/2 transform -translate-y-1/2 text-slate-400"></i>
                    <input type="text" placeholder="Quét mã QR hoặc Nhập Tên, Số Điện Thoại bệnh nhân..." class="w-full pl-12 pr-4 py-3.5 bg-white border border-slate-200 rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition shadow-sm font-medium">
                    <button class="absolute right-2 top-1/2 transform -translate-y-1/2 bg-slate-100 p-2 rounded-xl text-slate-500 hover:text-blue-600">
                        <i class="fas fa-qrcode"></i>
                    </button>
                </div>

                <!-- Bộ lọc trạng thái -->
                <div class="flex space-x-6 border-b border-slate-200 mb-6">
                    <button class="pb-3 text-sm font-bold text-blue-600 border-b-2 border-blue-600">Tất cả hôm nay</button>
                    <button class="pb-3 text-sm font-bold text-slate-400 hover:text-slate-700 transition">Chờ tiếp nhận (12)</button>
                    <button class="pb-3 text-sm font-bold text-slate-400 hover:text-slate-700 transition">Cần thu tiền (3)</button>
                </div>

                <!-- Bảng Danh Sách Khách Hàng (Dành cho Lễ Tân) -->
                <div class="bg-white rounded-3xl border border-slate-100 shadow-sm divide-y divide-slate-50">
                    
                    <!-- Khách 1: CHỜ TIẾP NHẬN (Cần Check-in) -->
                    <div class="p-5 flex flex-col md:flex-row md:items-center justify-between hover:bg-slate-50 transition first:rounded-t-3xl last:rounded-b-3xl gap-4">
                        <div class="flex items-center space-x-4 min-w-[250px]">
                            <div class="w-12 h-12 bg-blue-100 text-blue-600 font-black text-lg rounded-2xl flex items-center justify-center">
                                T
                            </div>
                            <div>
                                <h4 class="font-bold text-sm text-slate-800">Trần Phương Trang</h4>
                                <p class="text-xs text-slate-400 font-medium mt-0.5">SĐT: 0912 345 678</p>
                            </div>
                        </div>
                        
                        <div class="flex-1">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Giờ hẹn • Dịch vụ</p>
                            <p class="text-sm font-bold text-slate-700"><span class="text-blue-600">08:30 AM</span> • Khám Tổng Quát</p>
                        </div>

                        <div class="flex items-center justify-between min-w-[200px] gap-3">
                            <span class="inline-block px-3 py-1 bg-slate-100 text-slate-600 text-[10px] font-black rounded-lg uppercase border border-slate-200">Chưa đến</span>
                            <button class="bg-blue-50 text-blue-600 px-4 py-2 rounded-xl text-xs font-bold border border-blue-200 hover:bg-blue-600 hover:text-white transition shadow-sm">
                                <i class="fas fa-check-circle mr-1"></i> Check-in
                            </button>
                        </div>
                    </div>

                    <!-- Khách 2: CHỜ THANH TOÁN (Khám xong, ra quầy đóng tiền) -->
                    <div class="p-5 flex flex-col md:flex-row md:items-center justify-between hover:bg-slate-50 transition gap-4 bg-green-50/30">
                        <div class="flex items-center space-x-4 min-w-[250px]">
                            <img src="https://i.pravatar.cc/100?img=11" class="w-12 h-12 rounded-2xl object-cover">
                            <div>
                                <h4 class="font-bold text-sm text-slate-800">Lê Quốc Huy</h4>
                                <p class="text-xs text-slate-400 font-medium mt-0.5">SĐT: 0857 157 006</p>
                            </div>
                        </div>
                        
                        <div class="flex-1">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Chỉ định của bác sĩ</p>
                            <p class="text-sm font-bold text-slate-700">Siêu âm + Đơn thuốc nội khoa</p>
                        </div>

                        <div class="flex items-center justify-between min-w-[200px] gap-3">
                            <div class="text-right">
                                <p class="text-sm font-black text-green-700">450.000 ₫</p>
                                <span class="text-[9px] text-slate-400 uppercase font-bold">Chưa thanh toán</span>
                            </div>
                            <button class="bg-green-500 text-white px-4 py-2 rounded-xl text-xs font-bold hover:bg-green-600 transition shadow-sm shadow-green-200">
                                Thu Tiền
                            </button>
                        </div>
                    </div>

                    <!-- Khách 3: ĐANG CHỜ KHÁM (Đã Check-in, đang ngồi chờ ở sảnh) -->
                    <div class="p-5 flex flex-col md:flex-row md:items-center justify-between hover:bg-slate-50 transition gap-4">
                        <div class="flex items-center space-x-4 min-w-[250px]">
                            <img src="https://i.pravatar.cc/100?img=5" class="w-12 h-12 rounded-2xl object-cover">
                            <div>
                                <h4 class="font-bold text-sm text-slate-800">Nguyễn Bảo Nhi</h4>
                                <p class="text-xs text-slate-400 font-medium mt-0.5">SĐT: 0988 777 666</p>
                            </div>
                        </div>
                        
                        <div class="flex-1">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Đang chờ tại</p>
                            <p class="text-sm font-bold text-slate-700"><i class="fas fa-door-closed text-orange-400 mr-1"></i> Phòng khám Nhi (P.102)</p>
                        </div>

                        <div class="flex items-center justify-end min-w-[200px] gap-3 mr-2">
                            <span class="inline-block px-3 py-1.5 bg-orange-100 text-orange-600 text-[10px] font-black rounded-lg uppercase">Đang đợi BS gọi</span>
                        </div>
                    </div>

                </div>

            </div>
        </main>
    </div>

</body>
</html>