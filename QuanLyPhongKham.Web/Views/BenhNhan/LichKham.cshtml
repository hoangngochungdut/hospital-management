@model IEnumerable<QuanLyPhongKham.Models.BuoiKham>
@using QuanLyPhongKham.Models.Enums

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "";

    // PHÂN LOẠI VÀ SẮP XẾP DỮ LIỆU NGAY TỪ ĐẦU
    // 1. Chưa khám: Xếp TĂNG DẦN (Gần nhất hiện trước, 18 trước 28)
    var lichChuaKham = Model.Where(x => x.TrangThai == TrangThaiBuoiKham.ChuaXacNhan || x.TrangThai == TrangThaiBuoiKham.XacNhan)
                            .OrderBy(x => x.Ngay).ThenBy(x => x.Gio).ToList();

    // 2. Đã khám (Lịch sử): Xếp GIẢM DẦN (Vừa khám xong hiện trước)
    var lichDaKham = Model.Where(x => x.TrangThai == TrangThaiBuoiKham.HoanThanh || x.TrangThai == TrangThaiBuoiKham.Huy)
                          .OrderByDescending(x => x.Ngay).ThenByDescending(x => x.Gio).ToList();
}

@* ================= PHẦN 1: LỊCH CHƯA KHÁM (SẮP TỚI) ================= *@
<div class="mb-10">
    <h3 class="text-lg font-black text-blue-700 uppercase tracking-wider mb-4 flex items-center gap-2">
        <span>🕒 Lịch sắp tới (Chưa khám)</span>
        <span class="bg-blue-100 text-blue-800 text-xs px-2 py-0.5 rounded-full">@lichChuaKham.Count()</span>
    </h3>
                
    <div class="bg-white p-6 rounded-3xl shadow-md border border-slate-200 overflow-x-auto">
        @if (!lichChuaKham.Any())
        {
            <p class="text-slate-400 text-center py-6 italic text-sm">Bạn không có lịch khám nào sắp tới.</p>
        }
        else
        {
            <table class="w-full text-left border-collapse min-w-[800px]">
                <tr class="border-b-2 border-slate-100 text-slate-500 uppercase text-xs tracking-wider">
                    <th class="py-4 px-4">Thời gian</th>
                    <th class="py-4 px-4">Bác Sĩ & Chuyên Khoa</th>
                    <th class="py-4 px-4">Phòng</th>
                    <th class="py-4 px-4">Trạng Thái</th>
                    <th class="py-4 px-4 w-1/3">Thông tin & Phản hồi</th>
                </tr>
                @foreach (var item in lichChuaKham)
                {
                    <tr class="border-b border-slate-50 hover:bg-slate-50 transition-colors align-top">
                        <td class="py-4 px-4">
                            <div class="font-bold text-slate-700 text-base">@item.Ngay.ToString("dd/MM/yyyy")</div>
                            <div class="text-blue-600 font-black text-sm">@item.Gio.ToString("HH:mm")</div>
                        </td>
                        <td class="py-4 px-4">
                            <div class="font-bold text-sm text-slate-800">BS. @item.BacSi?.HoTen</div>
                            <div class="text-[11px] text-slate-500 font-medium mt-1">Khoa: @(item.BacSi?.ChuyenKhoa?.TenKhoa ?? "Đang cập nhật")</div>
                        </td>
                        <td class="py-4 px-4">
                            <span class="bg-slate-100 text-slate-600 px-3 py-1.5 rounded-lg text-xs font-bold border border-slate-200">P.@item.PhongKham?.SoPhong</span>
                        </td>
                        <td class="py-4 px-4">
                            @if (item.TrangThai == TrangThaiBuoiKham.ChuaXacNhan)
                            {
                                <span class="bg-yellow-50 border border-yellow-200 text-yellow-700 px-3 py-1 rounded-full text-xs font-bold">⏳ Chờ xác nhận</span>
                            }
                            else
                            {
                                <span class="bg-blue-50 border border-blue-200 text-blue-700 px-3 py-1 rounded-full text-xs font-bold">✅ Đã xác nhận</span>
                            }
                        </td>
                        <td class="py-4 px-4">
                            @if (!string.IsNullOrEmpty(item.ThongBaoChoBenhNhan))
                            {
                                <div class="mb-3 p-2 bg-red-50 border border-red-200 text-red-700 text-xs rounded-lg animate-pulse">
                                    <span class="font-bold">🔔 Tin nhắn:</span> @item.ThongBaoChoBenhNhan
                                </div>
                            }
                            <div class="flex gap-2 mb-3">
                                <button type="button" onclick="openBnMoveModal(@item.Id, @item.BacSiId, @item.PhongKhamId)" class="px-3 py-1.5 bg-orange-100 text-orange-600 rounded-lg text-[11px] font-bold hover:bg-orange-200 border border-orange-200 transition-all shadow-sm">
                                    🕒 Yêu cầu dời lịch
                                </button>
                                <button type="button" onclick="openBnCancelModal(@item.Id)" class="px-3 py-1.5 bg-red-100 text-red-600 rounded-lg text-[11px] font-bold hover:bg-red-200 border border-red-200 transition-all shadow-sm">
                                    ❌ Hủy lịch
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </table>
        }
    </div>
</div>

@* ================= PHẦN 2: LỊCH ĐÃ KHÁM (LỊCH SỬ) ================= *@
<div>
    <h3 class="text-lg font-black text-slate-500 uppercase tracking-wider mb-4 flex items-center gap-2">
        <span>📜 Lịch sử khám bệnh</span>
        <span class="bg-slate-200 text-slate-600 text-xs px-2 py-0.5 rounded-full">@lichDaKham.Count()</span>
    </h3>
                
    <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-200 overflow-x-auto opacity-90 hover:opacity-100 transition-opacity">
        @if (!lichDaKham.Any())
        {
            <p class="text-slate-400 text-center py-6 italic text-sm">Bạn chưa có lịch sử khám bệnh nào.</p>
        }
        else
        {
            <table class="w-full text-left border-collapse min-w-[800px]">
                <tr class="border-b-2 border-slate-100 text-slate-400 uppercase text-xs tracking-wider">
                    <th class="py-4 px-4">Thời gian</th>
                    <th class="py-4 px-4">Bác Sĩ & Chuyên Khoa</th>
                    <th class="py-4 px-4">Phòng</th>
                    <th class="py-4 px-4">Trạng Thái</th>
                    <th class="py-4 px-4 w-1/3">Kết luận & Phản hồi</th>
                </tr>
                @foreach (var item in lichDaKham)
                {
                    <tr class="border-b border-slate-50 hover:bg-slate-50 transition-colors align-top">
                        <td class="py-4 px-4">
                            <div class="font-bold text-slate-600">@item.Ngay.ToString("dd/MM/yyyy")</div>
                            <div class="text-slate-400 font-bold text-xs">@item.Gio.ToString("HH:mm")</div>
                        </td>
                        <td class="py-4 px-4 opacity-80">
                            <div class="font-bold text-sm text-slate-700">BS. @item.BacSi?.HoTen</div>
                            <div class="text-[11px] text-slate-400 font-medium mt-1">Khoa: @(item.BacSi?.ChuyenKhoa?.TenKhoa ?? "N/A")</div>
                        </td>
                        <td class="py-4 px-4 opacity-80">
                            <span class="bg-slate-50 text-slate-500 px-3 py-1.5 rounded-lg text-xs font-bold border border-slate-100">P.@item.PhongKham?.SoPhong</span>
                        </td>
                        <td class="py-4 px-4">
                            @if (item.TrangThai == TrangThaiBuoiKham.HoanThanh)
                            {
                                <span class="bg-green-50 border border-green-200 text-green-700 px-3 py-1 rounded-full text-xs font-bold">🎉 Hoàn thành</span>
                            }
                            else
                            {
                                <span class="bg-red-50 border border-red-200 text-red-700 px-3 py-1 rounded-full text-xs font-bold">❌ Đã hủy</span>
                            }
                        </td>
                        <td class="py-4 px-4">
                            @* Chỉ hiện ghi chú hoặc đánh giá nếu đã hoàn thành/hủy *@
                            @if (item.TrangThai == TrangThaiBuoiKham.Huy)
                            {
                                <div class="mb-2 text-xs text-red-600 bg-red-50 p-2 rounded-lg border border-red-100">
                                    <span class="font-bold">Lý do hủy:</span> @(item.GhiChuKetQua ?? item.ThongBaoChoBenhNhan ?? "Không có")
                                </div>
                            }
                            else if (item.TrangThai == TrangThaiBuoiKham.HoanThanh)
                            {
                                <div class="mb-3 text-xs text-slate-700 bg-blue-50 p-2 rounded-lg border border-blue-100">
                                    <span class="font-bold text-blue-800">Kết luận:</span> @(item.GhiChuKetQua ?? "Chưa có ghi chú")
                                </div>

                                if (item.DiemDanhGia == null)
                                {
                                    <form asp-controller="BenhNhanDashboard" asp-action="NopDanhGia" method="POST" class="bg-white border border-slate-200 p-3 rounded-xl shadow-sm">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <p class="text-[10px] font-bold text-orange-500 uppercase mb-2">Chấm điểm bác sĩ</p>
                                        <select name="soSao" class="w-full text-xs p-1.5 mb-2 border border-slate-200 rounded outline-none text-orange-500 font-bold" required>
                                            <option value="5">⭐⭐⭐⭐⭐ Tuyệt vời</option>
                                            <option value="4">⭐⭐⭐⭐ Hài lòng</option>
                                            <option value="3">⭐⭐⭐ Bình thường</option>
                                            <option value="2">⭐⭐ Tệ</option>
                                            <option value="1">⭐ Rất tệ</option>
                                        </select>
                                        <input type="text" name="nhanXet" class="w-full text-xs p-2 mb-2 border border-slate-200 rounded outline-none" placeholder="Chia sẻ cảm nhận của bạn..." required />
                                        <button type="submit" class="w-full bg-orange-500 text-white text-xs font-bold py-1.5 rounded hover:bg-orange-600 transition-all">Gửi Đánh Giá</button>
                                    </form>
                                }
                                else
                                {
                                    <div class="bg-orange-50 border border-orange-100 p-2 rounded-lg">
                                        <div class="text-xs mb-1" title="@item.DiemDanhGia Sao">
                                            @string.Concat(Enumerable.Repeat("⭐", item.DiemDanhGia.Value))
                                        </div>
                                        <p class="text-[11px] text-slate-600 italic">"@item.NhanXetCuaBenhNhan"</p>
                                    </div>
                                }
                            }
                        </td>
                    </tr>
                }
            </table>
        }
    </div>
</div>