@model QuanLyPhongKham.Models.DTOs.AddBenhNhanDto
@{
    ViewData["Title"] = "Thêm bệnh nhân";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="max-w-3xl mx-auto mt-6 bg-white rounded-xl shadow-lg overflow-hidden">

    <head>
        <title>Thêm bệnh nhân</title>
    </head>
    <!-- HEADER -->
    <div class="bg-blue-600 px-6 py-4">
        <h2 class="text-white text-lg font-semibold">
            Thêm bệnh nhân mới
        </h2>
    </div>

    <!-- BODY -->
    <div class="p-6 space-y-4">

        @if (TempData["Success"] != null)
        {
            <div class="bg-green-100 text-green-700 px-4 py-2 rounded">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="bg-red-100 text-red-700 px-4 py-2 rounded">
                @TempData["Error"]
            </div>
        }

        <form asp-action="Add" asp-controller="BenhNhan" method="post" class="space-y-4">
            @Html.AntiForgeryToken()

            <!-- Họ tên -->
            <div>
                <label class="block font-medium mb-1">Họ tên</label>

                <input asp-for="HoTen"
                       type="text"
                       class="w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400" />

                <span asp-validation-for="HoTen"
                      class="text-red-500 text-sm"></span>
            </div>

            <!-- Giới tính -->
            <div>
                <label class="block font-medium mb-1">Giới tính</label>
                <select name="GioiTinh"
                        class="w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400">
                    <option value="">--Chọn--</option>
                    <option value="Nam">Nam</option>
                    <option value="Nữ">Nữ</option>
                    <option value="Khác">Khác</option>
                </select>
            </div>

            <!-- SĐT -->
            <div>
                <label class="block font-medium mb-1">Số điện thoại</label>

                <input asp-for="SoDienThoai"
                       type="text"
                       class="w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400" />

                <span asp-validation-for="SoDienThoai"
                      class="text-red-500 text-sm"></span>
            </div>

            <!-- Email -->
            <div>
                <label class="block font-medium mb-1">Email</label>

                <input asp-for="Email"
                       type="text"
                       class="w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400" />

                <span asp-validation-for="Email"
                      class="text-red-500 text-sm"></span>
            </div>


            <!-- Địa chỉ -->
            <div>
                <label class="block font-medium mb-1">Địa chỉ</label>
                <textarea name="DiaChi"
                          rows="3"
                          class="w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400"></textarea>
            </div>

            <!--tên đăng nhập-->
            <div class="pt-4 border-t">
                <label class="block font-medium mb-1">Tên đăng nhập</label>
                <input type="text" name="TenDangNhap"
                       class="w-full border rounded-lg px-3 py-2" />
            </div>
            @if (ViewBag.Error != null)
            {
                <div class="mb-4 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
                    @ViewBag.Error
                </div>
            }

            <!-- Mật khẩu (nếu tạo luôn tài khoản) -->
            <div class="pt-4 border-t">
                <label class="block font-medium mb-1">Mật khẩu</label>
                <input type="text" name="MatKhau"
                       class="w-full border rounded-lg px-3 py-2" />
            </div>

            <!-- BUTTON -->
            <div class="pt-4 flex justify-end gap-3">
                <a href="@Url.Action("BenhNhan", "AdminDashboard")"
                       class="px-5 py-2 bg-slate-200 rounded-lg">
                    Quay lại
                </a>

                <button type="submit"
                        class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg">
                    Thêm
                </button>
            </div>

        </form>
    </div>
</div>