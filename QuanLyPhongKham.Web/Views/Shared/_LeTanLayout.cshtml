<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trang Chủ Admin - PBL3 Clinic</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .sidebar-item { transition: all 0.2s ease; }
        .sidebar-item:hover { background-color: #f1f5f9; color: #2563eb; }
        .sidebar-active { background-color: #eff6ff; color: #2563eb; border-right: 4px solid #2563eb; font-weight: 600; }
    </style>
</head>
<body class="bg-[#f8fafc] text-slate-800 antialiased">

    <!-- Wrapper chính -->
    <div class="flex min-h-screen">
        
        <!-- SIDEBAR (Fixed Left) -->
        <aside class="w-64 bg-white border-r border-slate-200 hidden lg:flex flex-col sticky top-0 h-screen shadow-sm">
            <div class="p-8">
                <div class="flex items-center space-x-3">
                    <div class="w-9 h-9 bg-blue-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-blue-200">
                        <i class="fas fa-plus-square text-lg"></i>
                    </div>
                    <span class="text-xl font-black tracking-tighter text-slate-800">PBL3<span class="text-blue-600">MED</span></span>
                </div>
            </div>

            <!-- MENU NAVIGATION -->
            <nav class="flex-1 px-4 space-y-1 overflow-y-auto">
                
                <!-- Nhóm 1: Hồ sơ cá nhân -->
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest px-4 mb-2">Tài khoản</p>
             <a href="@Url.Action("ThongTinCaNhan", "LeTanDashboard")" class="flex items-center space-x-3 px-4 py-3 rounded-lg sidebar-item text-slate-500">
    <i class="fas fa-id-card w-5"></i>
    <span>Thông Tin Cá Nhân</span>
</a>
                
                
                <!-- Nhóm 2: Nghiệp vụ chính -->
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest px-4 mt-6 mb-2">Chính</p>
                <!-- Đang set Active ở Lịch Khám, bạn dùng JS để đổi class "sidebar-active" khi chuyển tab -->
                <a href="@Url.Action("LichKham", "LeTanDashboard")" class="sidebar-active flex items-center space-x-3 px-4 py-3 rounded-lg sidebar-item">
                    <i class="fas fa-calendar-alt w-5"></i>
                    <span>Lịch Khám</span>
                </a>
                <a href="#" class="flex items-center space-x-3 px-4 py-3 rounded-lg sidebar-item text-slate-500">
                    <i class="fas fa-file-invoice-dollar w-5"></i>
                    <span>Thanh Toán</span>
                </a>
         
            </nav>

            <div class="p-4 border-t border-slate-100">
                <!-- ĐÃ THÊM ONCLICK Ở ĐÂY -->
                <a href="#" onclick="handleLogout(event)" class="flex items-center space-x-3 px-4 py-3 rounded-lg text-red-500 hover:bg-red-50 transition cursor-pointer">
                    <i class="fas fa-sign-out-alt w-5"></i>
                    <span class="font-semibold">Đăng Xuất</span>
                </a>
            </div>
        </aside>

     <!-- MAIN CONTENT AREA (Khu vực bên phải) -->
        <main class="flex-1 flex flex-col relative">
            
            <!-- TOP HEADER: Chứa thông tin Admin ở góc trên bên phải -->
            <header class="w-full px-8 py-6 flex justify-end items-center bg-transparent">
                
                <!-- PROFILE INFO -->
                <div class="flex items-center space-x-4 cursor-pointer hover:opacity-80 transition group">
                    <div class="text-right">
                        <h2 class="text-sm font-bold text-slate-800 leading-none">Giao diện cho lễ tân</h2>
                        <p class="text-[10px] text-blue-600 font-bold uppercase mt-1.5 tracking-wider">Lễ Tân</p>
                    </div>
                    
                    @* <!-- Avatar -->
                    <div class="relative">
                        <img src=" " class="w-10 h-10 rounded-xl object-cover shadow-sm border border-slate-200 transition-all group-hover:border-blue-400" alt="Avatar">
                        <div class="absolute bottom-[-2px] right-[-2px] w-3.5 h-3.5 bg-green-500 border-2 border-[#f8fafc] rounded-full"></div>
                    </div> *@
                </div>

            </header>

            <!-- VÙNG NỘI DUNG (Trắng bóc hoàn toàn) -->
            <!-- ID "main-app-content" là nơi bạn sẽ dùng JS/Backend để gọi dữ liệu hiển thị vào đây -->
            <div id="main-app-content" class="flex-1 w-full h-full p-8">
                @RenderBody()
            </div>

        </main>
        
    </div>
        <!-- SCRIPT XỬ LÝ ĐĂNG XUẤT (Đã chuyển xuống cuối body) -->
    <script>
        function handleLogout(event) {
            event.preventDefault(); 
            
            const isConfirmed = confirm("Bạn có chắc chắn muốn đăng xuất?");
            
            if (isConfirmed) {
                // Đảm bảo đường dẫn này đúng với route MVC của bạn
                window.location.href = "/Account/login"; 
            }
        }
    </script>
</body>
</html>