@using QuanLyPhongKham.Models
@model IEnumerable<BenhNhan>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản Trị Bệnh Nhân";
}

<div class="bg-white p-6 rounded-xl shadow border border-slate-200">

    <!-- HEADER -->
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-bold">Danh sách bệnh nhân</h2>

        <a asp-controller="BenhNhan"
               asp-action="Add"
               class="bg-blue-50 text-blue-600 border border-blue-200 hover:bg-blue-500 hover:text-white px-3 py-1.5 rounded text-sm transition-all font-medium">
            Thêm bệnh nhân
        </a>
    </div>

    <!-- THÔNG BÁO -->
    @if (TempData["Success"] != null)
    {
        <div class="mb-4 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="mb-4 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
            @TempData["Error"]
        </div>
    }

    <!-- BỘ LỌC -->
    <div class="bg-slate-50 border border-slate-200 rounded-lg p-4 mb-5">

        <div>
            <label class="block text-sm font-medium text-slate-600 mb-1">
                Tên bệnh nhân
            </label>

            <input type="text"
                   id="filterTen"
                   placeholder="Nhập tên bệnh nhân..."
                   class="w-full border border-slate-300 rounded-lg px-3 py-2 outline-none focus:ring-2 focus:ring-blue-400" />
        </div>

    </div>

    <!-- BẢNG -->
    <table class="w-full text-left">
        <thead>
            <tr class="border-b bg-slate-800 text-white">
                <th class="py-3 px-2">Họ tên</th>
                <th class="py-3 px-2">Địa chỉ</th>
                <th class="py-3 px-2">Số điện thoại</th>
                <th class="py-3 px-2">Thao tác</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var bn in Model ?? new List<BenhNhan>())
            {
                <tr class="border-b hover:bg-slate-50 transition-colors patient-row">

                    <!-- HỌ TÊN -->
                    <td class="py-3 px-2 font-bold text-blue-600 patient-name">
                        @bn.HoTen
                    </td>

                    <!-- ĐỊA CHỈ -->
                    <td class="py-3 px-2">
                        @(string.IsNullOrWhiteSpace(bn.DiaChi)
                            ? "Chưa có địa chỉ"
                            : bn.DiaChi)
                    </td>

                    <!-- SĐT -->
                    <td class="py-3 px-2">
                        @(string.IsNullOrWhiteSpace(bn.Sdt)
                            ? "Chưa có SĐT"
                            : bn.Sdt)
                    </td>

                    <!-- THAO TÁC -->
                    <td class="py-3 px-2">
                        <div class="flex items-center space-x-2">

                            <!-- Nút chi tiết -->
                            <a asp-controller="BenhNhan"
                                   asp-action="ChiTiet"
                                   asp-route-id="@bn.Id"
                                   class="bg-blue-50 text-blue-600 border border-blue-200 hover:bg-blue-500 hover:text-white px-3 py-1.5 rounded text-sm transition-all font-medium">
                                Chi tiết
                            </a>

                            <!-- Nút xóa -->
                            <form asp-controller="BenhNhan"
                                  asp-action="Delete"
                                  method="POST"
                                  class="m-0"
                                  onsubmit="return confirm('Bạn có chắc muốn xóa bệnh nhân @bn.HoTen?');">

                                <input type="hidden" name="id" value="@bn.Id" />

                                <button type="submit"
                                        class="bg-red-50 text-red-600 border border-red-200 hover:bg-red-500 hover:text-white px-3 py-1.5 rounded text-sm transition-all font-medium">
                                    Xóa
                                </button>
                            </form>

                        </div>
                    </td>

                </tr>
            }
        </tbody>
    </table>
</div>

<!-- SCRIPT FILTER -->
<script>
    const filterTen = document.getElementById("filterTen");

    const rows = document.querySelectorAll(".patient-row");

    function filterPatients() {

        const tenValue = filterTen.value.toLowerCase();

        rows.forEach(row => {

            const ten = row.querySelector(".patient-name")
                .innerText.toLowerCase();

            const matchTen = ten.includes(tenValue);

            if (matchTen) {
                row.style.display = "";
            }
            else {
                row.style.display = "none";
            }
        });
    }

    filterTen.addEventListener("input", filterPatients);
</script>