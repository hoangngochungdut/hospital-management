@model QuanLyPhongKham.Models.LeTan
@{
    Layout = "_AdminLayout";
}

<div class="max-w-3xl mx-auto space-y-6 py-8">
    <div class="flex items-center space-x-4 mb-8">
        <a href="@Url.Action("LeTan", "AdminDashboard")" class="p-2 bg-white rounded-full border border-slate-200 text-slate-400 hover:text-blue-600 transition-colors shadow-sm">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div>
            <h1 class="text-2xl font-black tracking-tighter text-slate-900">Chỉnh Sửa Thông Tin Lễ Tân</h1>
            <p class="text-sm text-slate-500 mt-1">Cập nhật thông tin định danh cho nhân viên.</p>
        </div>
    </div>

    <div class="bg-white rounded-3xl border border-slate-100 shadow-xl overflow-hidden">
        <form asp-action="SuaLeTan" method="post" class="p-8 space-y-6">
            <input type="hidden" asp-for="Id" />
            
            <div class="grid grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label class="text-sm font-bold text-slate-700 ml-1">Họ và Tên</label>
                    <input type="text" asp-for="HoTen" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:ring-2 focus:ring-blue-400 transition" required>
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-bold text-slate-700 ml-1">Số Điện Thoại</label>
                    <input type="text" asp-for="Sdt" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:ring-2 focus:ring-blue-400 transition" required>
                </div>
            </div>

            <div class="space-y-2">
                <label class="text-sm font-bold text-slate-700 ml-1">Địa Chỉ</label>
                <input type="text" asp-for="DiaChi" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none focus:ring-2 focus:ring-blue-400 transition">
            </div>

            <div class="space-y-2">
                <label class="text-sm font-bold text-slate-700 ml-1">Giới Tính</label>
                <select asp-for="GioiTinh" class="w-full px-4 py-3 rounded-xl border border-slate-200 outline-none bg-white cursor-pointer appearance-none focus:ring-2 focus:ring-blue-400 transition">
                    <option value="Nam">Nam</option>
                    <option value="Nữ">Nữ</option>
                </select>
            </div>

            <div class="flex items-center justify-end space-x-3 pt-6 border-t border-slate-50">
                <a href="@Url.Action("LeTan", "AdminDashboard")" class="px-6 py-3 rounded-xl bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold transition">
                    Hủy Bỏ
                </a>
                <button type="submit" class="px-8 py-3 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold shadow-lg shadow-blue-100 transition">
                    Lưu Thay Đổi
                </button>
            </div>
        </form>
    </div>
</div>