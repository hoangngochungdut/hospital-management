@using QuanLyPhongKham.Models
@model IEnumerable<BacSi>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản Trị Bác Sĩ";
}

<div class="bg-white p-6 rounded-xl shadow border border-slate-200">

    <!-- HEADER -->
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-bold">Danh sách bác sĩ</h2>

        <a asp-controller="BacSi"
               asp-action="Add"
               class="bg-blue-50 text-blue-600 border border-blue-200 hover:bg-blue-500 hover:text-white px-3 py-1.5 rounded text-sm transition-all font-medium">
            Thêm bác sĩ
        </a>
    </div>

    <!-- THÔNG BÁO -->
    @if (TempData["Success"] != null)
    {
        <div class="mb-4 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="mb-4 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
            @TempData["Error"]
        </div>
    }

    <!-- BỘ LỌC -->
    <div class="bg-slate-50 border border-slate-200 rounded-lg p-4 mb-5">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">

            <!-- Lọc theo tên -->
            <div>
                <label class="block text-sm font-medium text-slate-600 mb-1">
                    Tên bác sĩ
                </label>

                <input type="text"
                       id="filterTen"
                       placeholder="Nhập tên bác sĩ..."
                       class="w-full border border-slate-300 rounded-lg px-3 py-2 outline-none focus:ring-2 focus:ring-blue-400" />
            </div>

            <!-- Lọc theo chuyên khoa -->
            <div>
                <label class="block text-sm font-medium text-slate-600 mb-1">
                    Chuyên khoa
                </label>

                <input type="text"
                       id="filterChuyenKhoa"
                       placeholder="Nhập chuyên khoa..."
                       class="w-full border border-slate-300 rounded-lg px-3 py-2 outline-none focus:ring-2 focus:ring-blue-400" />
            </div>

        </div>
    </div>

    <!-- BẢNG -->
    <table class="w-full text-left">
        <thead>
            <tr class="border-b bg-slate-800 text-white">
                <th class="py-3 px-2">Họ tên</th>
                <th class="py-3 px-2">Chuyên khoa</th>
                <th class="py-3 px-2">Địa chỉ</th>
                <th class="py-3 px-2">Số điện thoại</th>
                <th class="py-3 px-2">Thao tác</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var bs in Model ?? new List<BacSi>())
            {
                <tr class="border-b hover:bg-slate-50 transition-colors doctor-row">

                    <!-- TÊN -->
                    <td class="py-3 px-2 font-bold text-blue-600 doctor-name">
                        @bs.HoTen
                    </td>

                    <!-- CHUYÊN KHOA -->
                    <td class="py-3 px-2 doctor-specialty">
                        @(bs.ChuyenKhoa?.TenKhoa ?? "Chưa phân chuyên khoa")
                    </td>

                    <!-- ĐỊA CHỈ -->
                    <td class="py-3 px-2">
                        @(string.IsNullOrWhiteSpace(bs.DiaChi)
                            ? "Chưa có địa chỉ"
                            : bs.DiaChi)
                    </td>

                    <!-- SĐT -->
                    <td class="py-3 px-2">
                        @(string.IsNullOrWhiteSpace(bs.Sdt)
                            ? "Chưa có SĐT"
                            : bs.Sdt)
                    </td>

                    <!-- THAO TÁC -->
                    <td class="py-3 px-2">
                        <div class="flex items-center space-x-2">

                            <!-- Nút chi tiết -->
                            <a asp-controller="BacSi"
                                   asp-action="ChiTiet"
                                   asp-route-id="@bs.Id"
                                   class="bg-blue-50 text-blue-600 border border-blue-200 hover:bg-blue-500 hover:text-white px-3 py-1.5 rounded text-sm transition-all font-medium">
                                Chi tiết
                            </a>

                            <!-- Nút xóa -->
                            <form asp-controller="BacSi"
                                  asp-action="Delete"
                                  method="POST"
                                  class="m-0"
                                  onsubmit="return confirm('Bạn có chắc muốn xóa bác sĩ @bs.HoTen?');">

                                <input type="hidden" name="id" value="@bs.Id" />

                                <button type="submit"
                                        class="bg-red-50 text-red-600 border border-red-200 hover:bg-red-500 hover:text-white px-3 py-1.5 rounded text-sm transition-all font-medium">
                                    Xóa
                                </button>
                            </form>

                        </div>
                    </td>

                </tr>
            }
        </tbody>
    </table>
</div>

<!-- SCRIPT FILTER -->
<script>
    const filterTen = document.getElementById("filterTen");
    const filterChuyenKhoa = document.getElementById("filterChuyenKhoa");

    const rows = document.querySelectorAll(".doctor-row");

    function filterDoctors() {

        const tenValue = filterTen.value.toLowerCase();
        const khoaValue = filterChuyenKhoa.value.toLowerCase();

        rows.forEach(row => {

            const ten = row.querySelector(".doctor-name")
                .innerText.toLowerCase();

            const khoa = row.querySelector(".doctor-specialty")
                .innerText.toLowerCase();

            const matchTen = ten.includes(tenValue);
            const matchKhoa = khoa.includes(khoaValue);

            if (matchTen && matchKhoa) {
                row.style.display = "";
            }
            else {
                row.style.display = "none";
            }
        });
    }

    filterTen.addEventListener("input", filterDoctors);
    filterChuyenKhoa.addEventListener("input", filterDoctors);
</script>