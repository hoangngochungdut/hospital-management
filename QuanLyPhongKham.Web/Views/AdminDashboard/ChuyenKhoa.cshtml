@using QuanLyPhongKham.Models
@model IEnumerable<ChuyenKhoa>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản Trị Chuyên Khoa";
}

<div class="bg-white p-6 rounded-xl shadow border border-slate-200">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-bold">Danh sách chuyên khoa</h2>

        <a asp-controller="ChuyenKhoa"
               asp-action="Add"
               class="bg-blue-50 text-blue-600 border border-blue-200 hover:bg-blue-500 hover:text-white px-3 py-1.5 rounded text-sm transition-all font-medium">
            Thêm chuyên khoa
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="mb-4 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
            @TempData["Error"]
        </div>
    }

    <table class="w-full text-left">
        <thead>
            <tr class="border-b bg-slate-800 text-white">
                <th class="py-3 px-2">Tên chuyên khoa</th>
                <th class="py-3 px-2">Mô tả</th>
                <th class="py-3 px-2">Thao tác</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var ck in Model ?? new List<ChuyenKhoa>())
            {
                <tr class="border-b hover:bg-slate-50 transition-colors">
                    
                    <td class="py-3 px-2 font-bold text-blue-600">
                        @ck.TenKhoa
                    </td>

                    <td class="py-3 px-2">
                        @(string.IsNullOrWhiteSpace(ck.MoTa)
                            ? "Chưa có mô tả"
                            : ck.MoTa)
                    </td>

                    <td class="py-3 px-2">
                        <div class="flex items-center space-x-2">

                            <!-- Sửa -->
                            <a asp-controller="ChuyenKhoa"
                                   asp-action="Edit"
                                   asp-route-id="@ck.Id"
                                   class="bg-yellow-50 text-yellow-600 border border-yellow-200 hover:bg-yellow-500 hover:text-white px-3 py-1.5 rounded text-sm transition-all font-medium">
                                Sửa
                            </a>

                            <!-- Xóa -->
                            <form asp-controller="ChuyenKhoa"
                                  asp-action="Delete"
                                  method="POST"
                                  class="m-0"
                                  onsubmit="return confirm('Bạn có chắc muốn xóa chuyên khoa @ck.TenKhoa?');">

                                <input type="hidden" name="id" value="@ck.Id" />

                                <button type="submit"
                                        class="bg-red-50 text-red-600 border border-red-200 hover:bg-red-500 hover:text-white px-3 py-1.5 rounded text-sm transition-all font-medium">
                                    Xóa
                                </button>
                            </form>

                        </div>
                    </td>

                </tr>
            }
        </tbody>
    </table>
</div>