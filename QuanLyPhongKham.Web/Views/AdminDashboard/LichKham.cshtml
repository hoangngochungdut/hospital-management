@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản trị Lịch Khám";
}

<div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
    <div class="flex justify-between items-center mb-6">
        <div>
            <h2 class="text-xl font-black text-slate-800">Quản Lý Toàn Bộ Lịch Khám</h2>
            <p class="text-sm text-slate-500 mt-1">Giao diện quản lý toàn quyền dành cho Admin.</p>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-800 text-white text-sm border-b border-slate-200">
                    <th class="py-4 px-4 font-medium rounded-tl-lg">ID</th>
                    <th class="py-4 px-4 font-medium">Thời Gian</th>
                    <th class="py-4 px-4 font-medium">Bệnh Nhân</th>
                    <th class="py-4 px-4 font-medium">Bác Sĩ</th>
                    <th class="py-4 px-4 font-medium">Trạng Thái</th>
                    <th class="py-4 px-4 font-medium text-right rounded-tr-lg">Hành Động Admin</th>
                </tr>
            </thead>
            <tbody>
                <tr class="border-b border-slate-100 hover:bg-slate-50 transition">
                    <td class="py-4 px-4 text-slate-500 font-mono">#LK1024</td>
                    <td class="py-4 px-4 text-slate-700">14:30<br><span class="text-xs text-slate-400">18/10/2026</span></td>
                    <td class="py-4 px-4 font-bold text-slate-800">Lê Đại Gia</td>
                    <td class="py-4 px-4 text-slate-600">BS. Trần A</td>
                    <td class="py-4 px-4">
                        <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-xs font-bold">Đã xác nhận</span>
                    </td>
                    <td class="py-4 px-4 flex justify-end space-x-2">
                        
                        <!-- Nút đổi trạng thái nhanh (Ví dụ: Hủy) -->
                        <form action="/AdminDashboard/CapNhatTrangThai" method="POST" class="inline">
                            <input type="hidden" name="id" value="1024" />
                            <input type="hidden" name="trangThai" value="3" /> <!-- 3: Hủy -->
                            <button type="submit" class="bg-orange-100 text-orange-700 p-2 rounded hover:bg-orange-200 transition" title="Chuyển sang Hủy">
                                <i class="fas fa-ban"></i>
                            </button>
                        </form>

                        <!-- Nút Xóa hẳn khỏi Database -->
                        <form action="/AdminDashboard/XoaLich" method="POST" class="inline" onsubmit="return confirm('Xóa vĩnh viễn lịch này?');">
                            <input type="hidden" name="id" value="1024" />
                            <button type="submit" class="bg-red-100 text-red-700 p-2 rounded hover:bg-red-200 transition" title="Xóa Data">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>