@model IEnumerable<QuanLyPhongKham.Models.BuoiKham>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản Trị Lịch Khám";
}

<div class="bg-white p-6 rounded-xl shadow border border-slate-200">
    <h2 class="text-xl font-bold mb-4">Toàn Bộ Lịch Khám Phòng Khám</h2>
    
    @if (TempData["Success"] != null)
    {
        <div class="mb-4 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative">
            @TempData["Error"]
        </div>
    }

    <table class="w-full text-left">
        <tr class="border-b bg-slate-800 text-white">
            <th class="py-3 px-2">Thời gian</th>
            <th class="py-3 px-2">Bệnh nhân</th>
            <th class="py-3 px-2">Bác sĩ</th>
            <th class="py-3 px-2">Phòng</th>
            <th class="py-3 px-2">Trạng thái</th>
            <th class="py-3 px-2">Admin Thao tác</th>
        </tr>
        @foreach (var item in Model)
        {
            <tr class="border-b hover:bg-slate-50 transition-colors">
                <td class="py-3 px-2">@item.Ngay.ToString("dd/MM/yyyy") - @item.Gio</td>
                <td class="py-3 px-2 font-bold text-blue-600">@item.BenhNhan?.HoTen</td>
                <td class="py-3 px-2 font-medium">BS. @item.BacSi?.HoTen</td>
                <td class="py-3 px-2">
                    <span class="bg-slate-100 px-2 py-1 rounded text-sm">P.@item.PhongKham?.SoPhong</span>
                </td>
                <td class="py-3 px-2">
                    @if ((int)item.TrangThai == 0)
                    {
                        <span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded text-xs font-bold">Chưa xác nhận</span>
                    }
                    else if ((int)item.TrangThai == 1)
                    {
                        <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs font-bold">Đã xác nhận</span>
                    }
                    else if ((int)item.TrangThai == 2)
                    {
                        <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs font-bold">Hoàn thành</span>
                    }
                    else
                    {
                        <span class="bg-red-100 text-red-700 px-2 py-1 rounded text-xs font-bold">Đã hủy</span>
                    }
                </td>
                <td class="py-3 px-2">
                    <div class="flex items-center space-x-2">
                        
                        <form asp-controller="AdminDashboard" asp-action="DoiTrangThai" method="POST" class="m-0">
                            <input type="hidden" name="id" value="@item.Id" />
                            <select name="trangThaiMoi" class="border border-slate-300 p-1.5 rounded text-sm bg-white cursor-pointer hover:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" onchange="this.form.submit()">
                                @if ((int)item.TrangThai == 0)
                                {
                                    <option value="0" selected>Chưa xác nhận</option>
                                }
                                else
                                {
                                    <option value="0">Chưa xác nhận</option>
                                }
                                @if ((int)item.TrangThai == 1)
                                {
                                    <option value="1" selected>Đã xác nhận</option>
                                }
                                else
                                {
                                    <option value="1">Đã xác nhận</option>
                                }
                                @if ((int)item.TrangThai == 2)
                                {
                                    <option value="2" selected>Hoàn thành</option>
                                }
                                else
                                {
                                    <option value="2">Hoàn thành</option>
                                }
                                @if ((int)item.TrangThai == 3)
                                {
                                    <option value="3" selected>Đã hủy</option>
                                }
                                else
                                {
                                    <option value="3">Đã hủy</option>
                                }
                            </select>
                        </form>

                        <form asp-controller="AdminDashboard" asp-action="XoaLich" method="POST" class="m-0"
                              onsubmit="return confirm('⚠️ Bạn có chắc chắn muốn xóa vĩnh viễn lịch khám của bệnh nhân @item.BenhNhan?.HoTen không?');">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="bg-red-50 text-red-600 border border-red-200 hover:bg-red-500 hover:text-white px-3 py-1.5 rounded text-sm transition-all font-medium flex items-center">
                                Xóa
                            </button>
                        </form>

                    </div>
                </td>
            </tr>
        }
    </table>
</div>